<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KLCMC.Pos.Maui.DailyAccountPage"
             Title="Daily Account"
             BackgroundColor="{DynamicResource ThemeBackgroundColor}">
  <Grid Padding="14"
        RowDefinitions="Auto,Auto,Auto,*,Auto"
        RowSpacing="14">

    <Border Stroke="{DynamicResource ThemeBorderColor}"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 14"
            BackgroundColor="{DynamicResource ThemeSurfaceColor}"
            Padding="14,10">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
        <Label Text="{Binding HeaderText}"
               FontSize="{DynamicResource FontSizeSectionTitle}"
               FontAttributes="Bold"
               TextColor="{DynamicResource ThemePrimaryTextColor}"
               VerticalOptions="Center" />
        <HorizontalStackLayout Grid.Column="1" Spacing="8">
          <Button Text="◀ Prev"
                  BackgroundColor="{DynamicResource ThemeBorderMutedColor}"
                  TextColor="{DynamicResource ThemePrimaryTextColor}"
                  Padding="12,6"
                  Command="{Binding PrevDayCommand}" />
          <Button Text="Today"
                  BackgroundColor="{DynamicResource ThemeActionBlueColor}"
                  TextColor="{DynamicResource ThemePrimaryTextColor}"
                  FontAttributes="Bold"
                  Padding="12,6"
                  Command="{Binding TodayCommand}" />
          <Button Text="Next ▶"
                  BackgroundColor="{DynamicResource ThemeBorderMutedColor}"
                  TextColor="{DynamicResource ThemePrimaryTextColor}"
                  Padding="12,6"
                  Command="{Binding NextDayCommand}" />
          <DatePicker Date="{Binding SelectedDate}"
                      TextColor="{DynamicResource ThemePrimaryTextColor}"
                      BackgroundColor="{DynamicResource ThemeSurfaceAltColor}"
                      FontSize="{DynamicResource FontSizeBodySmall}" />
        </HorizontalStackLayout>
      </Grid>
    </Border>

    <Grid Grid.Row="1"
          ColumnDefinitions="*,*,Auto"
          ColumnSpacing="14">
      <Border Grid.Column="0"
              Stroke="{DynamicResource ThemeBorderColor}"
              StrokeShape="RoundRectangle 14"
              BackgroundColor="{DynamicResource ThemeSurfaceColor}"
              Padding="16">
        <VerticalStackLayout Spacing="4">
          <Label Text="Transactions"
                 TextColor="{DynamicResource ThemeSecondaryTextColor}"
                 FontSize="{DynamicResource FontSizeBodySmall}" />
          <Label Text="{Binding TransactionCountText}"
                 TextColor="{DynamicResource ThemePrimaryTextColor}"
                 FontSize="{DynamicResource FontSizeSectionTitle}"
                 FontAttributes="Bold" />
        </VerticalStackLayout>
      </Border>
      <Border Grid.Column="1"
              Stroke="{DynamicResource ThemeBorderColor}"
              StrokeShape="RoundRectangle 14"
              BackgroundColor="{DynamicResource ThemeSurfaceColor}"
              Padding="16">
        <VerticalStackLayout Spacing="4">
          <Label Text="Gross Total"
                 TextColor="{DynamicResource ThemeSecondaryTextColor}"
                 FontSize="{DynamicResource FontSizeBodySmall}" />
          <Label Text="{Binding GrossTotalText}"
                 TextColor="{DynamicResource ThemeSuccessTextColor}"
                 FontSize="{DynamicResource FontSizeSectionTitle}"
                 FontAttributes="Bold" />
        </VerticalStackLayout>
      </Border>
      <Button Grid.Column="2"
              Text="🖨 Print Daily Report"
              BackgroundColor="{DynamicResource ThemeAccentColor}"
              TextColor="{DynamicResource ThemePrimaryButtonTextColor}"
              FontAttributes="Bold"
              Padding="16,12"
              Command="{Binding PrintDailyReportCommand}" />
    </Grid>

    <Border Grid.Row="2"
            Stroke="{DynamicResource ThemeBorderColor}"
            StrokeShape="RoundRectangle 14"
            BackgroundColor="{DynamicResource ThemeSurfaceColor}"
            Padding="14">
      <VerticalStackLayout Spacing="8">
        <Label Text="By Payment Method"
               FontSize="{DynamicResource FontSizeBody}"
               FontAttributes="Bold"
               TextColor="{DynamicResource ThemePrimaryTextColor}" />
        <CollectionView ItemsSource="{Binding ByMethod}">
          <CollectionView.EmptyView>
            <Label Text="No data."
                   TextColor="{DynamicResource ThemeSecondaryTextColor}"
                   FontSize="{DynamicResource FontSizeCaption}" />
          </CollectionView.EmptyView>
          <CollectionView.ItemsLayout>
            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
          </CollectionView.ItemsLayout>
          <CollectionView.ItemTemplate>
            <DataTemplate>
              <Border Stroke="{DynamicResource ThemeBorderColor}"
                      StrokeShape="RoundRectangle 10"
                      BackgroundColor="{DynamicResource ThemeSurfaceAltColor}"
                      Padding="14,10"
                      MinimumWidthRequest="160">
                <VerticalStackLayout Spacing="2">
                  <Label Text="{Binding Method}"
                         TextColor="{DynamicResource ThemeSecondaryTextColor}"
                         FontSize="{DynamicResource FontSizeCaption}" />
                  <Label TextColor="{DynamicResource ThemePrimaryTextColor}"
                         FontSize="{DynamicResource FontSizeBody}"
                         FontAttributes="Bold">
                    <Label.FormattedText>
                      <FormattedString>
                        <Span Text="HKD $" />
                        <Span Text="{Binding Amount, StringFormat='{0:F2}'}" />
                      </FormattedString>
                    </Label.FormattedText>
                  </Label>
                  <Label TextColor="{DynamicResource ThemeSecondaryTextColor}"
                         FontSize="{DynamicResource FontSizeMicro}">
                    <Label.FormattedText>
                      <FormattedString>
                        <Span Text="{Binding Count}" />
                        <Span Text=" txn(s)" />
                      </FormattedString>
                    </Label.FormattedText>
                  </Label>
                </VerticalStackLayout>
              </Border>
            </DataTemplate>
          </CollectionView.ItemTemplate>
        </CollectionView>
      </VerticalStackLayout>
    </Border>

    <Border Grid.Row="3"
            Stroke="{DynamicResource ThemeBorderColor}"
            StrokeShape="RoundRectangle 14"
            BackgroundColor="{DynamicResource ThemeSurfaceColor}"
            Padding="14">
      <Grid RowDefinitions="Auto,*" RowSpacing="8">
        <Label Text="Transactions"
               FontSize="{DynamicResource FontSizeBody}"
               FontAttributes="Bold"
               TextColor="{DynamicResource ThemePrimaryTextColor}" />
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Transactions}">
          <CollectionView.EmptyView>
            <Label Text="No transactions for the selected date."
                   TextColor="{DynamicResource ThemeSecondaryTextColor}"
                   FontSize="{DynamicResource FontSizeBodySmall}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
          </CollectionView.EmptyView>
          <CollectionView.ItemTemplate>
            <DataTemplate>
              <Border Stroke="{DynamicResource ThemeBorderColor}"
                      StrokeShape="RoundRectangle 10"
                      BackgroundColor="{DynamicResource ThemeSurfaceAltColor}"
                      Padding="14,10"
                      Margin="0,0,0,8">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                  <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label TextColor="{DynamicResource ThemePrimaryTextColor}"
                           FontSize="{DynamicResource FontSizeBodySmall}"
                           FontAttributes="Bold">
                      <Label.FormattedText>
                        <FormattedString>
                          <Span Text="#" />
                          <Span Text="{Binding Id}" />
                        </FormattedString>
                      </Label.FormattedText>
                    </Label>
                    <Label Text="{Binding CreatedAtLocal, StringFormat='{0:HH:mm:ss}'}"
                           TextColor="{DynamicResource ThemeSecondaryTextColor}"
                           FontSize="{DynamicResource FontSizeCaption}" />
                  </VerticalStackLayout>
                  <CollectionView Grid.Column="1"
                                  ItemsSource="{Binding Payments}">
                    <CollectionView.ItemsLayout>
                      <LinearItemsLayout Orientation="Horizontal" ItemSpacing="6" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                      <DataTemplate>
                        <Border Stroke="{DynamicResource ThemeActionBlueColor}"
                                StrokeShape="RoundRectangle 999"
                                BackgroundColor="{DynamicResource ThemeSurfaceColor}"
                                Padding="8,3">
                          <Label TextColor="{DynamicResource ThemePrimaryTextColor}"
                                 FontSize="{DynamicResource FontSizeCaption}">
                            <Label.FormattedText>
                              <FormattedString>
                                <Span Text="{Binding Method}" />
                                <Span Text=" $" />
                                <Span Text="{Binding Amount, StringFormat='{0:F2}'}" />
                              </FormattedString>
                            </Label.FormattedText>
                          </Label>
                        </Border>
                      </DataTemplate>
                    </CollectionView.ItemTemplate>
                  </CollectionView>
                  <Label Grid.Column="2"
                         TextColor="{DynamicResource ThemeSuccessTextColor}"
                         FontSize="{DynamicResource FontSizeBody}"
                         FontAttributes="Bold"
                         VerticalOptions="Center">
                    <Label.FormattedText>
                      <FormattedString>
                        <Span Text="$" />
                        <Span Text="{Binding Total, StringFormat='{0:F2}'}" />
                      </FormattedString>
                    </Label.FormattedText>
                  </Label>
                </Grid>
              </Border>
            </DataTemplate>
          </CollectionView.ItemTemplate>
        </CollectionView>
      </Grid>
    </Border>

    <Label Grid.Row="4"
           Text="{Binding StatusMessage}"
           TextColor="{DynamicResource ThemeSecondaryTextColor}"
           FontSize="{DynamicResource FontSizeCaption}" />
  </Grid>
</ContentPage>
