<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KLCMC.Pos.Maui.MainPage"
             Title="KLCMC POS"
             BackgroundColor="#031425">
  <Grid RowDefinitions="Auto,*"
        RowSpacing="14"
        Padding="16">
    <Border Stroke="#2A3B4C"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 14"
            BackgroundColor="#0F2131">
      <Grid Padding="14,10"
            ColumnDefinitions="Auto,*,Auto,Auto"
            ColumnSpacing="14">
        <VerticalStackLayout Spacing="0">
          <Label Text="KLCMC POS"
                 TextColor="#D2E4FB"
                 FontSize="22"
                 FontAttributes="Bold" />
          <Label Text="Dashboard"
                 TextColor="#8EA0B9"
                 FontSize="13" />
        </VerticalStackLayout>

        <Border Grid.Column="1"
                Stroke="#253648"
                StrokeShape="RoundRectangle 10"
                BackgroundColor="#1A2B3C"
                Padding="10,6">
          <Grid ColumnDefinitions="Auto,*"
                ColumnSpacing="8">
            <Label Text="🔎"
                   VerticalOptions="Center"
                   TextColor="#8EA0B9" />
            <Entry Grid.Column="1"
                   Placeholder="Search products..."
                   PlaceholderColor="#8EA0B9"
                   TextColor="#D2E4FB"
                   BackgroundColor="Transparent"
                   ClearButtonVisibility="WhileEditing" />
          </Grid>
        </Border>

        <Button Grid.Column="2"
                x:Name="DailyAccountButton"
                Text="📊 Daily Account"
                BackgroundColor="#1F3D5C"
                TextColor="#D2E4FB"
                FontAttributes="Bold"
                Padding="14,8"
                Clicked="OnDailyAccountClicked" />

        <Border Grid.Column="3"
                Stroke="#364E00"
                StrokeShape="RoundRectangle 999"
                BackgroundColor="#1C2A0B"
                Padding="12,6"
                VerticalOptions="Center">
          <HorizontalStackLayout Spacing="8">
            <Label Text="Printer"
                   TextColor="#D2E4FB"
                   VerticalOptions="Center" />
            <Label Text="{Binding ConnectionStateText}"
                   FontAttributes="Bold"
                   VerticalOptions="Center">
              <Label.Triggers>
                <DataTrigger TargetType="Label"
                             Binding="{Binding ConnectionStateText}"
                             Value="Connected">
                  <Setter Property="TextColor"
                          Value="#BDEE62" />
                </DataTrigger>
                <DataTrigger TargetType="Label"
                             Binding="{Binding ConnectionStateText}"
                             Value="Disconnected">
                  <Setter Property="TextColor"
                          Value="#FFB4AB" />
                </DataTrigger>
              </Label.Triggers>
            </Label>
          </HorizontalStackLayout>
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1"
          ColumnDefinitions="1*,1.5*"
          ColumnSpacing="14">
      <Border Grid.Column="1"
              Stroke="#2A3B4C"
              StrokeThickness="1"
              StrokeShape="RoundRectangle 14"
              BackgroundColor="#0F2131"
              Padding="12">
          <Grid RowDefinitions="Auto,*,Auto"
                RowSpacing="14">
            <HorizontalStackLayout Spacing="12"
                                   VerticalOptions="Center">
              <Label Text="Current Sale"
                     FontSize="40"
                     FontAttributes="Bold"
                     TextColor="#D2E4FB" />
              <Label Text="{Binding TotalText}"
                     FontSize="32"
                     FontAttributes="Bold"
                     TextColor="#A6D64D"
                     VerticalOptions="Center" />
            </HorizontalStackLayout>

            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding CartLines}"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedCartLine}">
              <CollectionView.ItemTemplate>
                <DataTemplate>
                  <Border Stroke="#253648"
                          StrokeThickness="1"
                          StrokeShape="RoundRectangle 10"
                          BackgroundColor="#1A2B3C"
                          Padding="14"
                          Margin="0,0,0,10">
                    <Grid ColumnDefinitions="2*,Auto,Auto,Auto"
                          ColumnSpacing="14">
                      <Label Text="{Binding Name}"
                             FontSize="28"
                             FontAttributes="Bold"
                             TextColor="#D2E4FB"
                             VerticalOptions="Center" />
                      <Label Grid.Column="1"
                             Text="{Binding Quantity, StringFormat='x{0}'}"
                             FontSize="28"
                             TextColor="#C4D4E8"
                             VerticalOptions="Center" />
                      <Label Grid.Column="2"
                             Text="{Binding UnitPrice, StringFormat='HKD $ {0:F2}'}"
                             FontSize="26"
                             TextColor="#69D4F8"
                             VerticalOptions="Center" />
                      <Label Grid.Column="3"
                             Text="{Binding LineTotal, StringFormat='HKD $ {0:F2}'}"
                             FontSize="28"
                             TextColor="#D2E4FB"
                             FontAttributes="Bold"
                             VerticalOptions="Center" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </CollectionView.ItemTemplate>
            </CollectionView>

            <Grid Grid.Row="2"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="10">
              <Label Text="{Binding StatusMessage}"
                     FontSize="22"
                     TextColor="#C4D4E8"
                     LineBreakMode="WordWrap" />
              <HorizontalStackLayout Grid.Row="1"
                                     Spacing="12">
                <Button Text="Clear"
                        FontSize="24"
                        FontAttributes="Bold"
                        HeightRequest="64"
                        Padding="24,0"
                        BackgroundColor="#253648"
                        TextColor="#D2E4FB"
                        Command="{Binding ClearCartCommand}" />
                <Button Text="Checkout"
                        FontSize="24"
                        FontAttributes="Bold"
                        HeightRequest="64"
                        Padding="24,0"
                        BackgroundColor="#A2D149"
                        TextColor="#243600"
                        Command="{Binding PrintReceiptCommand}" />
              </HorizontalStackLayout>
            </Grid>
          </Grid>
      </Border>

      <Grid Grid.Column="0"
            RowDefinitions="Auto,*,Auto,Auto"
            RowSpacing="10">
        <Border Stroke="#2A3B4C"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 14"
                BackgroundColor="#0F2131"
                Padding="12">
          <VerticalStackLayout Spacing="10">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="10">
              <VerticalStackLayout Spacing="2">
                <Label Text="Printer Connection"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#D2E4FB" />
                <Label Text="{Binding ConnectionStateText}">
                  <Label.Triggers>
                    <DataTrigger TargetType="Label"
                                 Binding="{Binding ConnectionStateText}"
                                 Value="Connected">
                      <Setter Property="TextColor"
                              Value="#BDEE62" />
                    </DataTrigger>
                    <DataTrigger TargetType="Label"
                                 Binding="{Binding ConnectionStateText}"
                                 Value="Disconnected">
                      <Setter Property="TextColor"
                              Value="#FFB4AB" />
                    </DataTrigger>
                  </Label.Triggers>
                </Label>
              </VerticalStackLayout>
              <Button Grid.Column="1"
                      Text="{Binding PrinterPanelToggleText}"
                      FontSize="12"
                      BackgroundColor="#1A2B3C"
                      TextColor="#D2E4FB"
                      Command="{Binding TogglePrinterPanelCommand}" />
            </Grid>

            <Grid IsVisible="{Binding IsPrinterPanelExpanded}"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="8"
                  RowSpacing="8">
              <Picker Grid.Row="0"
                      Grid.Column="0"
                      Title="Mode"
                      ItemsSource="{Binding ConnectionModes}"
                      SelectedItem="{Binding ConnectionOptions.Mode}" />
              <Entry Grid.Row="0"
                     Grid.Column="1"
                     Placeholder="Endpoint"
                     Text="{Binding ConnectionOptions.Endpoint}" />
              <Entry Grid.Row="1"
                     Grid.Column="0"
                     Placeholder="Baud Rate"
                     Keyboard="Numeric"
                     Text="{Binding ConnectionOptions.BaudRate}" />
              <Entry Grid.Row="1"
                     Grid.Column="1"
                     Placeholder="Data Bits"
                     Keyboard="Numeric"
                     Text="{Binding ConnectionOptions.DataBits}" />
              <Entry Grid.Row="2"
                     Grid.Column="0"
                     Placeholder="Stop Bits"
                     Keyboard="Numeric"
                     Text="{Binding ConnectionOptions.StopBits}" />
              <Entry Grid.Row="2"
                     Grid.Column="1"
                     Placeholder="Parity"
                     Keyboard="Numeric"
                     Text="{Binding ConnectionOptions.Parity}" />
              <Entry Grid.Row="3"
                     Grid.Column="0"
                     Placeholder="Flow Control"
                     Keyboard="Numeric"
                     Text="{Binding ConnectionOptions.FlowControl}" />
              <HorizontalStackLayout Grid.Row="4"
                                     Grid.ColumnSpan="2"
                                     Spacing="8">
                <Button Text="Connect"
                        BackgroundColor="#209DC0"
                        TextColor="White"
                        FontAttributes="Bold"
                        Command="{Binding ConnectPrinterCommand}" />
                <Button Text="Disconnect"
                        BackgroundColor="#253648"
                        TextColor="#D2E4FB"
                        FontAttributes="Bold"
                        Command="{Binding DisconnectPrinterCommand}" />
              </HorizontalStackLayout>
            </Grid>
          </VerticalStackLayout>
        </Border>

        <Border Grid.Row="1"
                Stroke="#2A3B4C"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 14"
                BackgroundColor="#0F2131"
                Padding="14">
          <Grid RowDefinitions="Auto,*"
                RowSpacing="12">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="10">
              <Label Text="Products"
                     TextColor="#D2E4FB"
                     FontSize="24"
                     FontAttributes="Bold" />
              <Button Grid.Column="1"
                      Text="+ New Product"
                      FontAttributes="Bold"
                      BackgroundColor="#A2D149"
                      TextColor="#243600"
                      Command="{Binding OpenAddProductPopupCommand}" />
            </Grid>

            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding PresetItems}"
                            SelectionMode="None">
              <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="3"
                                 HorizontalItemSpacing="10"
                                 VerticalItemSpacing="10" />
              </CollectionView.ItemsLayout>
              <CollectionView.ItemTemplate>
                <DataTemplate>
                  <Border Stroke="#253648"
                          StrokeThickness="1"
                          StrokeShape="RoundRectangle 10"
                          BackgroundColor="#1A2B3C"
                          Padding="12"
                          MinimumHeightRequest="110">
                    <Border.GestureRecognizers>
                      <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AddItemCommand}"
                                            CommandParameter="{Binding}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8"
                                         VerticalOptions="Center"
                                         HorizontalOptions="Center">
                      <Label Text="{Binding Name}"
                             FontSize="18"
                             FontAttributes="Bold"
                             TextColor="#D2E4FB"
                             HorizontalTextAlignment="Center" />
                      <Label Text="{Binding DefaultPrice, StringFormat='HKD $ {0:F2}'}"
                             TextColor="#69D4F8"
                             FontAttributes="Bold"
                             HorizontalTextAlignment="Center" />
                      <Label Text="Tap to add"
                             FontSize="12"
                             TextColor="#8EA0B9"
                             HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                  </Border>
                </DataTemplate>
              </CollectionView.ItemTemplate>
            </CollectionView>
          </Grid>
        </Border>

        <Border Grid.Row="2"
                Stroke="#2A3B4C"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 14"
                BackgroundColor="#0F2131"
                Padding="12">
          <VerticalStackLayout Spacing="10">
            <Label Text="Product Control"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#D2E4FB" />
            <Label Text="{Binding SelectedCartLineName}"
                   TextColor="#C4D4E8"
                   FontAttributes="Bold" />
            <Label Text="{Binding SelectedCartLineTotalText}"
                   TextColor="#8EA0B9"
                   FontSize="12" />

            <Entry Text="{Binding SelectedCartLine.Remark, Mode=TwoWay, FallbackValue=''}"
                   Placeholder="Add remark for this item..."
                   PlaceholderColor="#8EA0B9"
                   TextColor="#D2E4FB"
                   BackgroundColor="#1A2B3C"
                   IsEnabled="{Binding HasSelectedCartLine}" />

            <Border Stroke="#253648"
                    StrokeShape="RoundRectangle 10"
                    BackgroundColor="#1A2B3C"
                    Padding="12,8">
              <Label Text="{Binding PricePadInputText, StringFormat='HKD $ {0}'}"
                     TextColor="#BDEE62"
                     FontSize="28"
                     FontAttributes="Bold"
                     HorizontalTextAlignment="End" />
            </Border>

            <Grid RowDefinitions="*,*,*,*"
                  ColumnDefinitions="1.1*,*,*,*,1.1*"
                  ColumnSpacing="8"
                  RowSpacing="8"
                  IsEnabled="{Binding HasSelectedCartLine}">
              <Grid.Resources>
                <Style x:Key="NumKey" TargetType="Button">
                  <Setter Property="HeightRequest" Value="60" />
                  <Setter Property="FontSize" Value="22" />
                  <Setter Property="FontAttributes" Value="Bold" />
                  <Setter Property="BackgroundColor" Value="#1A2B3C" />
                  <Setter Property="TextColor" Value="#D2E4FB" />
                  <Setter Property="BorderColor" Value="#2A3B4C" />
                  <Setter Property="BorderWidth" Value="1" />
                  <Setter Property="CornerRadius" Value="10" />
                </Style>
                <Style x:Key="SideKey" TargetType="Button" BasedOn="{StaticResource NumKey}">
                  <Setter Property="BackgroundColor" Value="#209DC0" />
                  <Setter Property="TextColor" Value="White" />
                  <Setter Property="FontSize" Value="16" />
                </Style>
                <Style x:Key="QuickAmount" TargetType="Button" BasedOn="{StaticResource NumKey}">
                  <Setter Property="BackgroundColor" Value="#E07A5F" />
                  <Setter Property="TextColor" Value="White" />
                  <Setter Property="FontSize" Value="18" />
                </Style>
                <Style x:Key="ActionKey" TargetType="Button" BasedOn="{StaticResource NumKey}">
                  <Setter Property="BackgroundColor" Value="#A2D149" />
                  <Setter Property="TextColor" Value="#243600" />
                </Style>
              </Grid.Resources>

              <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource SideKey}"
                      Text="Cash"
                      Command="{Binding SetPricePadAmountCommand}"
                      CommandParameter="0" />
              <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource SideKey}"
                      Text="Alipay"
                      Command="{Binding SetPricePadAmountCommand}"
                      CommandParameter="0" />
              <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource SideKey}"
                      Text="WeChat Pay"
                      Command="{Binding SetPricePadAmountCommand}"
                      CommandParameter="0" />
              <Button Grid.Row="3" Grid.Column="0" Style="{StaticResource SideKey}"
                      Text="Card"
                      Command="{Binding SetPricePadAmountCommand}"
                      CommandParameter="0" />

              <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource NumKey}" Text="1"
                      Command="{Binding PricePadInputCommand}" CommandParameter="1" />
              <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource NumKey}" Text="2"
                      Command="{Binding PricePadInputCommand}" CommandParameter="2" />
              <Button Grid.Row="0" Grid.Column="3" Style="{StaticResource NumKey}" Text="3"
                      Command="{Binding PricePadInputCommand}" CommandParameter="3" />
              <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource NumKey}" Text="4"
                      Command="{Binding PricePadInputCommand}" CommandParameter="4" />
              <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource NumKey}" Text="5"
                      Command="{Binding PricePadInputCommand}" CommandParameter="5" />
              <Button Grid.Row="1" Grid.Column="3" Style="{StaticResource NumKey}" Text="6"
                      Command="{Binding PricePadInputCommand}" CommandParameter="6" />
              <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource NumKey}" Text="7"
                      Command="{Binding PricePadInputCommand}" CommandParameter="7" />
              <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource NumKey}" Text="8"
                      Command="{Binding PricePadInputCommand}" CommandParameter="8" />
              <Button Grid.Row="2" Grid.Column="3" Style="{StaticResource NumKey}" Text="9"
                      Command="{Binding PricePadInputCommand}" CommandParameter="9" />
              <Button Grid.Row="3" Grid.Column="1" Style="{StaticResource NumKey}" Text="0"
                      Command="{Binding PricePadInputCommand}" CommandParameter="0" />
              <Button Grid.Row="3" Grid.Column="2" Style="{StaticResource NumKey}" Text="00"
                      Command="{Binding PricePadInputCommand}" CommandParameter="00" />
              <Button Grid.Row="3" Grid.Column="3" Style="{StaticResource NumKey}" Text="."
                      Command="{Binding PricePadInputCommand}" CommandParameter="." />

              <Button Grid.Row="0" Grid.Column="4" Style="{StaticResource QuickAmount}" Text="$100"
                      Command="{Binding SetPricePadAmountCommand}" CommandParameter="100" />
              <Button Grid.Row="1" Grid.Column="4" Style="{StaticResource QuickAmount}" Text="$50"
                      Command="{Binding SetPricePadAmountCommand}" CommandParameter="50" />
              <Button Grid.Row="2" Grid.Column="4" Style="{StaticResource QuickAmount}" Text="$20"
                      Command="{Binding SetPricePadAmountCommand}" CommandParameter="20" />
              <Button Grid.Row="3" Grid.Column="4" Style="{StaticResource QuickAmount}" Text="$10"
                      Command="{Binding SetPricePadAmountCommand}" CommandParameter="10" />
            </Grid>

            <Grid ColumnDefinitions="*,*,2*"
                  ColumnSpacing="8"
                  IsEnabled="{Binding HasSelectedCartLine}">
              <Button Grid.Column="0"
                      Text="Delete"
                      HeightRequest="56"
                      FontSize="18"
                      FontAttributes="Bold"
                      BackgroundColor="#1A2B3C"
                      TextColor="#D2E4FB"
                      BorderColor="#2A3B4C"
                      BorderWidth="1"
                      CornerRadius="10"
                      Command="{Binding PricePadBackspaceCommand}" />
              <Button Grid.Column="1"
                      Text="Clear"
                      HeightRequest="56"
                      FontSize="18"
                      FontAttributes="Bold"
                      BackgroundColor="#1A2B3C"
                      TextColor="#D2E4FB"
                      BorderColor="#2A3B4C"
                      BorderWidth="1"
                      CornerRadius="10"
                      Command="{Binding PricePadClearCommand}" />
              <Button Grid.Column="2"
                      Text="Apply Price"
                      HeightRequest="56"
                      FontSize="20"
                      FontAttributes="Bold"
                      BackgroundColor="#A2D149"
                      TextColor="#243600"
                      CornerRadius="10"
                      Command="{Binding ApplyFinalPriceCommand}" />
            </Grid>
          </VerticalStackLayout>
        </Border>

        <Label Grid.Row="3"
               Text="On macOS, current default printer implementation is mock/file output."
               FontSize="12"
               TextColor="#8EA0B9"
               Opacity="0.9" />
      </Grid>
    </Grid>
    <Grid Grid.RowSpan="2"
          IsVisible="{Binding IsAddProductPopupVisible}"
          BackgroundColor="#80000000">
      <Border Stroke="#2A3B4C"
              StrokeThickness="1"
              StrokeShape="RoundRectangle 14"
              BackgroundColor="#0F2131"
              Padding="16"
              HorizontalOptions="Center"
              VerticalOptions="Center"
              MaximumWidthRequest="520">
        <VerticalStackLayout Spacing="12">
          <Label Text="Add New Product"
                 FontSize="24"
                 FontAttributes="Bold"
                 TextColor="#D2E4FB" />

          <Entry Placeholder="Product name"
                 Text="{Binding NewProductName}" />
          <Entry Placeholder="Price (e.g. 12.5)"
                 Keyboard="Numeric"
                 Text="{Binding NewProductPriceText}" />

          <Grid ColumnDefinitions="*,*"
                ColumnSpacing="10">
            <Button Grid.Column="0"
                    Text="Cancel"
                    BackgroundColor="#253648"
                    TextColor="#D2E4FB"
                    FontAttributes="Bold"
                    Command="{Binding CloseAddProductPopupCommand}" />
            <Button Grid.Column="1"
                    Text="Add Product"
                    BackgroundColor="#A2D149"
                    TextColor="#243600"
                    FontAttributes="Bold"
                    Command="{Binding AddNewProductCommand}" />
          </Grid>
        </VerticalStackLayout>
      </Border>
    </Grid>

    <!-- Checkout popup -->
    <Grid Grid.RowSpan="2"
          IsVisible="{Binding IsCheckoutPopupVisible}"
          BackgroundColor="#A0000000">
      <Border Stroke="#2A3B4C"
              StrokeThickness="1"
              StrokeShape="RoundRectangle 14"
              BackgroundColor="#0F2131"
              Padding="20"
              HorizontalOptions="Center"
              VerticalOptions="Center"
              MaximumWidthRequest="900"
              MinimumWidthRequest="720">
        <Grid RowDefinitions="Auto,Auto,*,Auto"
              RowSpacing="14">

          <VerticalStackLayout Grid.Row="0" Spacing="2">
            <Label Text="Checkout"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#D2E4FB" />
            <Label Text="{Binding AmountDueText}"
                   FontSize="22"
                   TextColor="#BDEE62"
                   FontAttributes="Bold" />
            <Label Text="{Binding PaidTotalText}"
                   FontSize="18"
                   TextColor="#D2E4FB" />
            <Label Text="{Binding OutstandingText}"
                   FontSize="18"
                   TextColor="#FFD479"
                   FontAttributes="Bold" />
          </VerticalStackLayout>

          <!-- payments list -->
          <Border Grid.Row="1"
                  Stroke="#2A3B4C"
                  StrokeShape="RoundRectangle 10"
                  BackgroundColor="#1A2B3C"
                  Padding="10"
                  MinimumHeightRequest="80">
            <CollectionView ItemsSource="{Binding Payments}"
                            HeightRequest="120">
              <CollectionView.EmptyView>
                <Label Text="No payments added yet."
                       TextColor="#8EA0B9"
                       FontSize="14"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
              </CollectionView.EmptyView>
              <CollectionView.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="*,Auto"
                        Padding="6,4"
                        ColumnSpacing="8">
                    <Label Text="{Binding DisplayText}"
                           TextColor="#D2E4FB"
                           FontSize="16"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Text="Remove"
                            FontSize="12"
                            BackgroundColor="#3D1F1F"
                            TextColor="#FFB4AB"
                            Padding="10,4"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemovePaymentCommand}"
                            CommandParameter="{Binding}" />
                  </Grid>
                </DataTemplate>
              </CollectionView.ItemTemplate>
            </CollectionView>
          </Border>

          <!-- method picker + numpad -->
          <Grid Grid.Row="2"
                ColumnDefinitions="1.1*,1.4*"
                ColumnSpacing="14">
            <VerticalStackLayout Grid.Column="0" Spacing="10">
              <Label Text="Payment Method"
                     TextColor="#8EA0B9"
                     FontSize="14" />
              <Picker ItemsSource="{Binding PaymentMethods}"
                      SelectedItem="{Binding SelectedNewPaymentMethod}"
                      TextColor="#D2E4FB"
                      BackgroundColor="#1A2B3C"
                      FontSize="18" />
              <Label Text="{Binding MoneyPadLabelText}"
                     TextColor="#8EA0B9"
                     FontSize="14" />
              <Border Stroke="#2A3B4C"
                      StrokeShape="RoundRectangle 10"
                      BackgroundColor="#1A2B3C"
                      Padding="14,10">
                <Label Text="{Binding MoneyPadInputText}"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="#D2E4FB"
                       HorizontalTextAlignment="End" />
              </Border>
              <Label Text="{Binding ChangePreviewText}"
                     FontSize="16"
                     TextColor="#BDEE62"
                     FontAttributes="Bold" />
              <Button Text="Add Payment"
                      FontSize="20"
                      FontAttributes="Bold"
                      HeightRequest="56"
                      BackgroundColor="#1F3D5C"
                      TextColor="#D2E4FB"
                      Command="{Binding AddPaymentCommand}" />
            </VerticalStackLayout>

            <Grid Grid.Column="1"
                  RowDefinitions="*,*,*,*,*"
                  ColumnDefinitions="*,*,*,*"
                  RowSpacing="8"
                  ColumnSpacing="8">
              <Button Grid.Row="0" Grid.Column="0" Text="7" FontSize="22" Command="{Binding MoneyPadInputCommand}" CommandParameter="7" />
              <Button Grid.Row="0" Grid.Column="1" Text="8" FontSize="22" Command="{Binding MoneyPadInputCommand}" CommandParameter="8" />
              <Button Grid.Row="0" Grid.Column="2" Text="9" FontSize="22" Command="{Binding MoneyPadInputCommand}" CommandParameter="9" />
              <Button Grid.Row="0" Grid.Column="3" Text="20" FontSize="18" BackgroundColor="#253648" TextColor="#D2E4FB" Command="{Binding MoneyPadQuickAmountCommand}" CommandParameter="20" />

              <Button Grid.Row="1" Grid.Column="0" Text="4" FontSize="22" Command="{Binding MoneyPadInputCommand}" CommandParameter="4" />
              <Button Grid.Row="1" Grid.Column="1" Text="5" FontSize="22" Command="{Binding MoneyPadInputCommand}" CommandParameter="5" />
              <Button Grid.Row="1" Grid.Column="2" Text="6" FontSize="22" Command="{Binding MoneyPadInputCommand}" CommandParameter="6" />
              <Button Grid.Row="1" Grid.Column="3" Text="50" FontSize="18" BackgroundColor="#253648" TextColor="#D2E4FB" Command="{Binding MoneyPadQuickAmountCommand}" CommandParameter="50" />

              <Button Grid.Row="2" Grid.Column="0" Text="1" FontSize="22" Command="{Binding MoneyPadInputCommand}" CommandParameter="1" />
              <Button Grid.Row="2" Grid.Column="1" Text="2" FontSize="22" Command="{Binding MoneyPadInputCommand}" CommandParameter="2" />
              <Button Grid.Row="2" Grid.Column="2" Text="3" FontSize="22" Command="{Binding MoneyPadInputCommand}" CommandParameter="3" />
              <Button Grid.Row="2" Grid.Column="3" Text="100" FontSize="18" BackgroundColor="#253648" TextColor="#D2E4FB" Command="{Binding MoneyPadQuickAmountCommand}" CommandParameter="100" />

              <Button Grid.Row="3" Grid.Column="0" Text="0" FontSize="22" Command="{Binding MoneyPadInputCommand}" CommandParameter="0" />
              <Button Grid.Row="3" Grid.Column="1" Text="00" FontSize="22" Command="{Binding MoneyPadInputCommand}" CommandParameter="00" />
              <Button Grid.Row="3" Grid.Column="2" Text="." FontSize="22" Command="{Binding MoneyPadInputCommand}" CommandParameter="." />
              <Button Grid.Row="3" Grid.Column="3" Text="500" FontSize="18" BackgroundColor="#253648" TextColor="#D2E4FB" Command="{Binding MoneyPadQuickAmountCommand}" CommandParameter="500" />

              <Button Grid.Row="4" Grid.Column="0" Text="C" FontSize="20" BackgroundColor="#3D1F1F" TextColor="#FFB4AB" Command="{Binding MoneyPadClearCommand}" />
              <Button Grid.Row="4" Grid.Column="1" Text="⌫" FontSize="20" BackgroundColor="#3D1F1F" TextColor="#FFB4AB" Command="{Binding MoneyPadBackspaceCommand}" />
              <Button Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" Text="Exact" FontSize="18" FontAttributes="Bold" BackgroundColor="#1C2A0B" TextColor="#BDEE62" Command="{Binding MoneyPadQuickAmountCommand}" CommandParameter="EXACT" />
            </Grid>
          </Grid>

          <!-- footer buttons -->
          <Grid Grid.Row="3"
                ColumnDefinitions="*,*"
                ColumnSpacing="12">
            <Button Grid.Column="0"
                    Text="Cancel"
                    FontSize="20"
                    HeightRequest="58"
                    BackgroundColor="#253648"
                    TextColor="#D2E4FB"
                    FontAttributes="Bold"
                    Command="{Binding CancelCheckoutCommand}" />
            <Button Grid.Column="1"
                    Text="Confirm &amp; Print"
                    FontSize="20"
                    HeightRequest="58"
                    BackgroundColor="#A2D149"
                    TextColor="#243600"
                    FontAttributes="Bold"
                    Command="{Binding ConfirmCheckoutCommand}" />
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</ContentPage>
