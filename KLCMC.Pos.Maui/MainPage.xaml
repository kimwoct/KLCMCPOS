<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:KLCMC.Pos.Maui.Converters"
             xmlns:models="clr-namespace:KLCMC.Pos.Core.Models;assembly=KLCMC.Pos.Core"
             xmlns:vm="clr-namespace:KLCMC.Pos.Core.ViewModels;assembly=KLCMC.Pos.Core"
             x:Class="KLCMC.Pos.Maui.MainPage"
             x:Name="RootPage"
             Title=""
             BackgroundColor="{DynamicResource ThemeBackgroundColor}">
  <ContentPage.Resources>
    <conv:BoolToTileBgConverter x:Key="BoolToTileBg"/>
    <conv:BoolToTileBgConverter x:Key="BoolToConnectedColorConverter"
                                SelectedColor="#BDEE62"
                                UnselectedColor="#FFB4AB"/>
    <Style TargetType="Label">
      <Setter Property="TextColor" Value="{DynamicResource ThemePrimaryTextColor}"/>
      <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
    </Style>
    <Style TargetType="Button">
      <Setter Property="TextColor" Value="{DynamicResource ThemePrimaryTextColor}"/>
      <Setter Property="FontSize" Value="{DynamicResource FontSizeBodySmall}"/>
    </Style>
    <Style TargetType="Entry">
      <Setter Property="TextColor" Value="{DynamicResource ThemePrimaryTextColor}"/>
      <Setter Property="BackgroundColor" Value="{DynamicResource ThemeSurfaceColor}"/>
      <Setter Property="FontSize" Value="{DynamicResource FontSizeBodySmall}"/>
    </Style>
    <Style TargetType="DatePicker">
      <Setter Property="TextColor" Value="{DynamicResource ThemePrimaryTextColor}"/>
      <Setter Property="BackgroundColor" Value="{DynamicResource ThemeSurfaceAltColor}"/>
      <Setter Property="FontSize" Value="{DynamicResource FontSizeBodySmall}"/>
    </Style>
    <Style x:Key="DangerRoundIconButtonStyle" TargetType="Button">
      <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
      <Setter Property="FontAttributes" Value="Bold"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="CornerRadius" Value="18"/>
      <Setter Property="BackgroundColor" Value="{DynamicResource ThemeDangerSurfaceColor}"/>
      <Setter Property="TextColor" Value="{DynamicResource ThemeDangerTextColor}"/>
    </Style>
    <Style x:Key="NumpadButtonStyle" TargetType="Button">
      <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
      <Setter Property="FontAttributes" Value="Bold"/>
      <Setter Property="BackgroundColor" Value="{DynamicResource ThemeSurfaceAltColor}"/>
      <Setter Property="TextColor" Value="{DynamicResource ThemePrimaryTextColor}"/>
      <Setter Property="BorderColor" Value="{DynamicResource ThemeBorderColor}"/>
      <Setter Property="BorderWidth" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
    </Style>
    <Style x:Key="QuickAmountButtonStyle" TargetType="Button" BasedOn="{StaticResource NumpadButtonStyle}">
      <Setter Property="BackgroundColor" Value="{DynamicResource ThemeQuickAmountColor}"/>
      <Setter Property="TextColor" Value="{DynamicResource ThemeWhiteColor}"/>
      <Setter Property="FontSize" Value="{DynamicResource FontSizeNumeric}"/>
    </Style>
  </ContentPage.Resources>
  <Grid RowDefinitions="*"
        RowSpacing="14"
        Padding="16">
    <Grid ColumnDefinitions="1*,1.5*"
          ColumnSpacing="14">
      <Border Grid.Column="1"
              Stroke="{DynamicResource ThemeBorderColor}"
              StrokeThickness="1"
              StrokeShape="RoundRectangle 14"
              BackgroundColor="{DynamicResource ThemeSurfaceColor}"
              Padding="12">
        <Grid RowDefinitions="Auto,*"
              RowSpacing="12">
          <Grid ColumnDefinitions="*,*,*"
                ColumnSpacing="10">
            <Button x:Name="CurrentSaleTabButton"
                    Text="當前銷售"
                    FontAttributes="Bold"
                    HeightRequest="44"
                    BackgroundColor="{DynamicResource ThemeActionBlueColor}"
                    TextColor="{DynamicResource ThemePrimaryTextColor}"
                    Clicked="OnCurrentSaleTabClicked"/>
            <Button Grid.Column="1"
                    x:Name="DailyAccountTabButton"
                    Text="📊 每日帳目"
                    FontAttributes="Bold"
                    HeightRequest="44"
                    BackgroundColor="{DynamicResource ThemeBorderMutedColor}"
                    TextColor="{DynamicResource ThemeSecondaryTextColor}"
                    Clicked="OnDailyAccountTabClicked"/>
            <Button Grid.Column="2"
                    x:Name="ConfigureTabButton"
                    Text="⚙ 設置"
                    FontAttributes="Bold"
                    HeightRequest="44"
                    BackgroundColor="{DynamicResource ThemeBorderMutedColor}"
                    TextColor="{DynamicResource ThemeSecondaryTextColor}"
                    Clicked="OnConfigureTabClicked"/>
          </Grid>

          <Grid Grid.Row="1">
            <Grid x:Name="CurrentSaleTabContent"
                  RowDefinitions="Auto,*,Auto"
                  RowSpacing="14">
              <HorizontalStackLayout Spacing="12"
                                     VerticalOptions="Center">
                <Label Text="當前銷售"
                       FontSize="{DynamicResource FontSizePageTitle}"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource ThemePrimaryTextColor}"/>
                <Label Text="{Binding TotalText}"
                       FontSize="{DynamicResource FontSizePageSubTitle}"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource ThemeAccentColor}"
                       VerticalOptions="Center"/>
              </HorizontalStackLayout>

              <CollectionView Grid.Row="1"
                              ItemsSource="{Binding CartLines}"
                              SelectionMode="Single"
                              SelectedItem="{Binding SelectedCartLine}">
                <CollectionView.ItemsLayout>
                  <LinearItemsLayout Orientation="Vertical"
                                     ItemSpacing="8"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                  <DataTemplate>
                    <Border Stroke="{DynamicResource ThemeBorderMutedColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{DynamicResource ThemeSurfaceAltColor}"
                            Padding="12"
                            Margin="0,0,0,4">
                      <VisualStateManager.VisualStateGroups>
                        <VisualStateGroupList>
                          <VisualStateGroup Name="CommonStates">
                            <VisualState Name="Normal">
                              <VisualState.Setters>
                                <Setter Property="StrokeThickness"
                                    Value="1"/>
                                <Setter Property="Stroke"
                                    Value="{DynamicResource ThemeBorderMutedColor}"/>
                              </VisualState.Setters>
                            </VisualState>
                            <VisualState Name="Selected">
                              <VisualState.Setters>
                                <Setter Property="StrokeThickness"
                                    Value="4"/>
                                <Setter Property="Stroke"
                                    Value="{DynamicResource ThemeHighlightColor}"/>
                              </VisualState.Setters>
                            </VisualState>
                          </VisualStateGroup>
                        </VisualStateGroupList>
                      </VisualStateManager.VisualStateGroups>
                      <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                            ColumnSpacing="10">
                        <Label FontSize="{DynamicResource FontSizeNumeric}"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource ThemePrimaryTextColor}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               VerticalOptions="Center">
                          <Label.FormattedText>
                            <FormattedString>
                              <Span Text="{Binding Name}"/>
                              <Span Text=" ("/>
                               <Span Text="{Binding UnitPrice, StringFormat='HKD $ {0:F2}'}"
                                    TextColor="{DynamicResource ThemeHighlightColor}"
                                    FontSize="{DynamicResource FontSizeButton}"/>
                              <Span Text=")"/>
                            </FormattedString>
                          </Label.FormattedText>
                        </Label>
                        <Label Grid.Column="1"
                               Text="{Binding Quantity, StringFormat='x{0}'}"
                               FontSize="{DynamicResource FontSizeButton}"
                               TextColor="{DynamicResource ThemeTertiaryTextColor}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="2"
                               Text="{Binding LineTotal, StringFormat='HKD $ {0:F2}'}"
                               FontSize="{DynamicResource FontSizeButton}"
                               TextColor="{DynamicResource ThemePrimaryTextColor}"
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>
                        <Button Grid.Column="3"
                                Text="−"
                                FontSize="{DynamicResource FontSizeNumeric}"
                                WidthRequest="40"
                                HeightRequest="40"
                                Padding="0"
                                CornerRadius="20"
                                BackgroundColor="{DynamicResource ThemeDangerSurfaceColor}"
                                TextColor="{DynamicResource ThemeDangerTextColor}"
                                VerticalOptions="Center"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveCartLineCommand}"
                                CommandParameter="{Binding}"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </CollectionView.ItemTemplate>
              </CollectionView>

              <Grid Grid.Row="2"
                    ColumnDefinitions="*,Auto"
                    ColumnSpacing="12">
                <Label Text="{Binding StatusMessage}"
                       FontSize="{DynamicResource FontSizeBody}"
                       TextColor="{DynamicResource ThemeSecondaryTextColor}"
                       LineBreakMode="TailTruncation"
                       VerticalOptions="Center"
                       HorizontalTextAlignment="End"/>
                <Button Grid.Column="1"
                        Text="結帳"
                        FontSize="{DynamicResource FontSizeButton}"
                        FontAttributes="Bold"
                        HeightRequest="64"
                        MinimumWidthRequest="150"
                        Padding="28,0"
                        BackgroundColor="{DynamicResource ThemeAccentColor}"
                        TextColor="{DynamicResource ThemePrimaryButtonTextColor}"
                        Command="{Binding PrintReceiptCommand}"/>
              </Grid>

              <BoxView Grid.RowSpan="3"
                       IsVisible="{Binding IsProductControlVisible}"
                       BackgroundColor="{DynamicResource ThemeOverlayColor}"
                       ZIndex="11"/>
              <Border x:Name="ProductControlPopup"
                      Grid.RowSpan="3"
                      IsVisible="{Binding IsProductControlVisible}"
                      Stroke="{DynamicResource ThemeBorderColor}"
                      StrokeThickness="1"
                      StrokeShape="RoundRectangle 14"
                      BackgroundColor="{DynamicResource ThemeSurfaceColor}"
                      Padding="12"
                      ZIndex="12"
                      MinimumWidthRequest="500"
                      MaximumWidthRequest="760"
                      HorizontalOptions="Center"
                      VerticalOptions="Center">
                <Border.GestureRecognizers>
                  <PanGestureRecognizer PanUpdated="OnProductControlPanUpdated"/>
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="10">
                  <Grid ColumnDefinitions="*,Auto">
                    <Label Text="產品控制"
                           FontSize="{DynamicResource FontSizeSectionTitle}"
                           FontAttributes="Bold"
                           TextColor="{DynamicResource ThemePrimaryTextColor}"
                           VerticalOptions="Center"/>
                    <Button Grid.Column="1"
                            Text="✕"
                            FontSize="{DynamicResource FontSizeBody}"
                            FontAttributes="Bold"
                            WidthRequest="36"
                            HeightRequest="36"
                            Padding="0"
                            CornerRadius="18"
                            BackgroundColor="{DynamicResource ThemeDangerSurfaceColor}"
                            TextColor="{DynamicResource ThemeDangerTextColor}"
                            VerticalOptions="Start"
                            Command="{Binding DismissProductControlCommand}"/>
                  </Grid>

                  <Entry Text="{Binding SelectedCartLine.Remark, Mode=TwoWay, FallbackValue=''}"
                         Placeholder="{Binding SelectedCartLineName}"
                         PlaceholderColor="{DynamicResource ThemeSuccessTextColor}"
                         TextColor="{DynamicResource ThemePrimaryTextColor}"
                         FontSize="{DynamicResource FontSizePageTitle}"
                         BackgroundColor="{DynamicResource ThemeSurfaceAltColor}"
                         IsEnabled="{Binding HasSelectedCartLine}"/>

                  <Border Stroke="{DynamicResource ThemeBorderMutedColor}"
                          StrokeShape="RoundRectangle 10"
                          BackgroundColor="{DynamicResource ThemeSurfaceAltColor}"
                          Padding="12,8">
                    <Label Text="{Binding PricePadInputText, StringFormat='HKD $ {0}'}"
                           TextColor="{DynamicResource ThemeSuccessTextColor}"
                           FontSize="{DynamicResource FontSizePageTitle}"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End"/>
                  </Border>

                  <Grid RowDefinitions="*,*,*,*"
                        ColumnDefinitions="*,*,*,*"
                        ColumnSpacing="8"
                        RowSpacing="8"
                        IsEnabled="{Binding HasSelectedCartLine}">
                    <Grid.Resources>
                      <Style x:Key="NumKey"
                          TargetType="Button">
                        <Setter Property="HeightRequest"
                            Value="60"/>
                        <Setter Property="FontSize"
                            Value="{DynamicResource FontSizeNumeric}"/>
                        <Setter Property="FontAttributes"
                            Value="Bold"/>
                        <Setter Property="BackgroundColor"
                            Value="{DynamicResource ThemeSurfaceAltColor}"/>
                        <Setter Property="TextColor"
                            Value="{DynamicResource ThemePrimaryTextColor}"/>
                        <Setter Property="BorderColor"
                            Value="{DynamicResource ThemeBorderColor}"/>
                        <Setter Property="BorderWidth"
                            Value="1"/>
                        <Setter Property="CornerRadius"
                            Value="10"/>
                      </Style>
                      <Style x:Key="QuickAmount"
                          TargetType="Button"
                          BasedOn="{StaticResource NumKey}">
                        <Setter Property="BackgroundColor"
                            Value="{DynamicResource ThemeQuickAmountColor}"/>
                        <Setter Property="TextColor"
                            Value="{DynamicResource ThemeWhiteColor}"/>
                        <Setter Property="FontSize"
                            Value="{DynamicResource FontSizeNumeric}"/>
                      </Style>
                    </Grid.Resources>

                    <Button Grid.Row="0"
                        Grid.Column="0"
                        Style="{StaticResource NumKey}"
                        Text="1"
                            Command="{Binding PricePadInputCommand}"
                        CommandParameter="1"/>
                    <Button Grid.Row="0"
                        Grid.Column="1"
                        Style="{StaticResource NumKey}"
                        Text="2"
                            Command="{Binding PricePadInputCommand}"
                        CommandParameter="2"/>
                    <Button Grid.Row="0"
                        Grid.Column="2"
                        Style="{StaticResource NumKey}"
                        Text="3"
                            Command="{Binding PricePadInputCommand}"
                        CommandParameter="3"/>
                    <Button Grid.Row="0"
                        Grid.Column="3"
                        Style="{StaticResource QuickAmount}"
                        Text="$100"
                            Command="{Binding SetPricePadAmountCommand}"
                        CommandParameter="100"/>

                    <Button Grid.Row="1"
                        Grid.Column="0"
                        Style="{StaticResource NumKey}"
                        Text="4"
                            Command="{Binding PricePadInputCommand}"
                        CommandParameter="4"/>
                    <Button Grid.Row="1"
                        Grid.Column="1"
                        Style="{StaticResource NumKey}"
                        Text="5"
                            Command="{Binding PricePadInputCommand}"
                        CommandParameter="5"/>
                    <Button Grid.Row="1"
                        Grid.Column="2"
                        Style="{StaticResource NumKey}"
                        Text="6"
                            Command="{Binding PricePadInputCommand}"
                        CommandParameter="6"/>
                    <Button Grid.Row="1"
                        Grid.Column="3"
                        Style="{StaticResource QuickAmount}"
                        Text="$50"
                            Command="{Binding SetPricePadAmountCommand}"
                        CommandParameter="50"/>

                    <Button Grid.Row="2"
                        Grid.Column="0"
                        Style="{StaticResource NumKey}"
                        Text="7"
                            Command="{Binding PricePadInputCommand}"
                        CommandParameter="7"/>
                    <Button Grid.Row="2"
                        Grid.Column="1"
                        Style="{StaticResource NumKey}"
                        Text="8"
                            Command="{Binding PricePadInputCommand}"
                        CommandParameter="8"/>
                    <Button Grid.Row="2"
                        Grid.Column="2"
                        Style="{StaticResource NumKey}"
                        Text="9"
                            Command="{Binding PricePadInputCommand}"
                        CommandParameter="9"/>
                    <Button Grid.Row="2"
                        Grid.Column="3"
                        Style="{StaticResource QuickAmount}"
                        Text="$20"
                            Command="{Binding SetPricePadAmountCommand}"
                        CommandParameter="20"/>

                    <Button Grid.Row="3"
                        Grid.Column="0"
                        Style="{StaticResource NumKey}"
                        Text="0"
                            Command="{Binding PricePadInputCommand}"
                        CommandParameter="0"/>
                    <Button Grid.Row="3"
                        Grid.Column="1"
                        Style="{StaticResource NumKey}"
                        Text="00"
                            Command="{Binding PricePadInputCommand}"
                        CommandParameter="00"/>
                    <Button Grid.Row="3"
                        Grid.Column="2"
                        Style="{StaticResource NumKey}"
                        Text="."
                            Command="{Binding PricePadInputCommand}"
                        CommandParameter="."/>
                    <Button Grid.Row="3"
                        Grid.Column="3"
                        Style="{StaticResource QuickAmount}"
                        Text="$10"
                            Command="{Binding SetPricePadAmountCommand}"
                        CommandParameter="10"/>
                  </Grid>

                  <Grid ColumnDefinitions="*,*,2*"
                        ColumnSpacing="8"
                        IsEnabled="{Binding HasSelectedCartLine}">
                    <Button Grid.Column="0"
                            Text="C"
                            HeightRequest="56"
                            FontSize="{DynamicResource FontSizeSectionTitle}"
                            FontAttributes="Bold"
                            BackgroundColor="{DynamicResource ThemeDangerSurfaceColor}"
                            TextColor="{DynamicResource ThemeDangerTextColor}"
                            BorderColor="{DynamicResource ThemeBorderColor}"
                            BorderWidth="1"
                            CornerRadius="10"
                            Command="{Binding PricePadClearCommand}"/>
                    <Button Grid.Column="1"
                            Text="⌫"
                            HeightRequest="56"
                            FontSize="{DynamicResource FontSizeSectionTitle}"
                            FontAttributes="Bold"
                            BackgroundColor="{DynamicResource ThemeDangerSurfaceColor}"
                            TextColor="{DynamicResource ThemeDangerTextColor}"
                            BorderColor="{DynamicResource ThemeBorderColor}"
                            BorderWidth="1"
                            CornerRadius="10"
                            Command="{Binding PricePadBackspaceCommand}"/>
                    <Button Grid.Column="2"
                            Text="套用價格"
                            HeightRequest="56"
                            FontSize="{DynamicResource FontSizeButton}"
                            FontAttributes="Bold"
                            BackgroundColor="{DynamicResource ThemeAccentColor}"
                            TextColor="{DynamicResource ThemePrimaryButtonTextColor}"
                            CornerRadius="10"
                            Command="{Binding ApplyFinalPriceCommand}"/>
                  </Grid>
                </VerticalStackLayout>
              </Border>
            </Grid>

            <!-- Checkout modal backdrop -->
            <BoxView IsVisible="{Binding IsCheckoutPopupVisible}"
                     BackgroundColor="{DynamicResource ThemeBlackColor}"
                     Opacity="0.55"
                     ZIndex="9"/>

            <!-- Checkout modal overlay -->
            <ScrollView IsVisible="{Binding IsCheckoutPopupVisible}"
                        ZIndex="10"
                        VerticalOptions="Center"
                        HorizontalOptions="Fill"
                        Margin="20">
              <Border Stroke="{DynamicResource ThemeBorderColor}"
                      StrokeThickness="1"
                      StrokeShape="RoundRectangle 16"
                      BackgroundColor="{DynamicResource ThemeModalSurfaceColor}"
                      Padding="14">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                      RowSpacing="10">
                  <!-- Row 0: totals + close X -->
                  <Grid Grid.Row="0"
                        ColumnDefinitions="*,*,*,Auto"
                        ColumnSpacing="10">
                    <VerticalStackLayout Grid.Column="0"
                        Spacing="0">
                      <Label Text="應付金額"
                          FontSize="{DynamicResource FontSizeBodySmall}"
                          TextColor="{DynamicResource ThemeSecondaryTextColor}"/>
                      <Label Text="{Binding AmountDueText}"
                          FontSize="{DynamicResource FontSizeSectionTitle}"
                          FontAttributes="Bold"
                          TextColor="{DynamicResource ThemeSuccessTextColor}"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1"
                        Spacing="0">
                      <Label Text="已付"
                          FontSize="{DynamicResource FontSizeBodySmall}"
                          TextColor="{DynamicResource ThemeSecondaryTextColor}"/>
                      <Label Text="{Binding PaidTotalText}"
                          FontSize="{DynamicResource FontSizeSectionTitle}"
                          FontAttributes="Bold"
                          TextColor="{DynamicResource ThemePrimaryTextColor}"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="2"
                        Spacing="0">
                      <Label Text="餘額"
                          FontSize="{DynamicResource FontSizeBodySmall}"
                          TextColor="{DynamicResource ThemeSecondaryTextColor}"/>
                      <Label Text="{Binding OutstandingText}"
                          FontSize="{DynamicResource FontSizeSectionTitle}"
                          FontAttributes="Bold"
                          TextColor="{DynamicResource ThemeWarningTextColor}"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="3"
                            Text="✕"
                            FontSize="{DynamicResource FontSizeSectionTitle}"
                            FontAttributes="Bold"
                            WidthRequest="36"
                            HeightRequest="36"
                            Padding="0"
                            CornerRadius="18"
                            BackgroundColor="{DynamicResource ThemeDangerSurfaceColor}"
                            TextColor="{DynamicResource ThemeDangerTextColor}"
                            VerticalOptions="Start"
                            Command="{Binding CancelCheckoutCommand}"/>
                  </Grid>

                  <!-- Row 1: payment method tiles (dynamic) -->
                  <FlexLayout Grid.Row="1"
                              Wrap="Wrap"
                              Direction="Row"
                              JustifyContent="Start"
                              AlignItems="Start">
                    <BindableLayout.ItemsSource>
                      <Binding Path="CheckoutMethodOptions"/>
                    </BindableLayout.ItemsSource>
                    <BindableLayout.ItemTemplate>
                      <DataTemplate x:DataType="vm:CheckoutMethodOption">
                        <Button Text="{Binding Name}"
                                FontSize="{DynamicResource FontSizeBodySmall}"
                                FontAttributes="Bold"
                                HeightRequest="52"
                                MinimumWidthRequest="90"
                                Margin="0,0,6,6"
                                TextColor="{DynamicResource ThemePrimaryTextColor}"
                                BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToTileBg}}"
                                Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.SelectPaymentMethodCommand}"
                                CommandParameter="{Binding Name}"/>
                      </DataTemplate>
                    </BindableLayout.ItemTemplate>
                  </FlexLayout>

                  <!-- Row 2: payments list -->
                  <Border Grid.Row="2"
                          Stroke="{DynamicResource ThemeBorderColor}"
                          StrokeShape="RoundRectangle 8"
                          BackgroundColor="{DynamicResource ThemeSurfaceAltColor}"
                          Padding="8"
                          MinimumHeightRequest="60">
                    <CollectionView ItemsSource="{Binding Payments}"
                                    HeightRequest="80">
                      <CollectionView.EmptyView>
                        <Label Text="尚未新增付款。"
                               TextColor="{DynamicResource ThemeSecondaryTextColor}"
                               FontSize="{DynamicResource FontSizeBodySmall}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                      </CollectionView.EmptyView>
                      <CollectionView.ItemTemplate>
                        <DataTemplate>
                          <Grid ColumnDefinitions="*,Auto"
                                Padding="6,3"
                                ColumnSpacing="8">
                            <Label Text="{Binding DisplayText}"
                                   TextColor="{DynamicResource ThemePrimaryTextColor}"
                                   FontSize="{DynamicResource FontSizeBody}"
                                   VerticalOptions="Center"/>
                            <Button Grid.Column="1"
                                    Text="刪除"
                                    FontSize="{DynamicResource FontSizeCaption}"
                                    BackgroundColor="{DynamicResource ThemeDangerSurfaceColor}"
                                    TextColor="{DynamicResource ThemeDangerTextColor}"
                                    Padding="10,4"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemovePaymentCommand}"
                                    CommandParameter="{Binding}"/>
                          </Grid>
                        </DataTemplate>
                      </CollectionView.ItemTemplate>
                    </CollectionView>
                  </Border>

                  <!-- Row 3: money pad -->
                  <Grid Grid.Row="3"
                        ColumnDefinitions="*">
                    <Grid RowDefinitions="Auto,*,*,*,*,Auto"
                          ColumnDefinitions="*,*,*,*"
                          RowSpacing="6"
                          ColumnSpacing="6">
                      <Border Grid.Row="0"
                              Grid.ColumnSpan="4"
                              Stroke="{DynamicResource ThemeBorderColor}"
                              StrokeShape="RoundRectangle 10"
                              BackgroundColor="{DynamicResource ThemeSurfaceAltColor}"
                              Padding="14,8">
                        <Label Text="{Binding MoneyPadInputText, StringFormat='HKD $ {0}'}"
                               TextColor="{DynamicResource ThemeSuccessTextColor}"
                               FontSize="{DynamicResource FontSizeNumeric}"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="End"/>
                      </Border>

                      <Button Grid.Row="1"
                          Grid.Column="0"
                          Style="{StaticResource NumpadButtonStyle}"
                          Text="1"
                          HeightRequest="54"
                          Command="{Binding MoneyPadInputCommand}"
                          CommandParameter="1"/>
                      <Button Grid.Row="1"
                          Grid.Column="1"
                          Style="{StaticResource NumpadButtonStyle}"
                          Text="2"
                          HeightRequest="54"
                          Command="{Binding MoneyPadInputCommand}"
                          CommandParameter="2"/>
                      <Button Grid.Row="1"
                          Grid.Column="2"
                          Style="{StaticResource NumpadButtonStyle}"
                          Text="3"
                          HeightRequest="54"
                          Command="{Binding MoneyPadInputCommand}"
                          CommandParameter="3"/>
                      <Button Grid.Row="1"
                          Grid.Column="3"
                          Style="{StaticResource QuickAmountButtonStyle}"
                          Text="$100"
                          HeightRequest="54"
                          Command="{Binding MoneyPadQuickAmountCommand}"
                          CommandParameter="100"/>

                      <Button Grid.Row="2"
                          Grid.Column="0"
                          Style="{StaticResource NumpadButtonStyle}"
                          Text="4"
                          HeightRequest="54"
                          Command="{Binding MoneyPadInputCommand}"
                          CommandParameter="4"/>
                      <Button Grid.Row="2"
                          Grid.Column="1"
                          Style="{StaticResource NumpadButtonStyle}"
                          Text="5"
                          HeightRequest="54"
                          Command="{Binding MoneyPadInputCommand}"
                          CommandParameter="5"/>
                      <Button Grid.Row="2"
                          Grid.Column="2"
                          Style="{StaticResource NumpadButtonStyle}"
                          Text="6"
                          HeightRequest="54"
                          Command="{Binding MoneyPadInputCommand}"
                          CommandParameter="6"/>
                      <Button Grid.Row="2"
                          Grid.Column="3"
                          Style="{StaticResource QuickAmountButtonStyle}"
                          Text="$50"
                          HeightRequest="54"
                          Command="{Binding MoneyPadQuickAmountCommand}"
                          CommandParameter="50"/>

                      <Button Grid.Row="3"
                          Grid.Column="0"
                          Style="{StaticResource NumpadButtonStyle}"
                          Text="7"
                          HeightRequest="54"
                          Command="{Binding MoneyPadInputCommand}"
                          CommandParameter="7"/>
                      <Button Grid.Row="3"
                          Grid.Column="1"
                          Style="{StaticResource NumpadButtonStyle}"
                          Text="8"
                          HeightRequest="54"
                          Command="{Binding MoneyPadInputCommand}"
                          CommandParameter="8"/>
                      <Button Grid.Row="3"
                          Grid.Column="2"
                          Style="{StaticResource NumpadButtonStyle}"
                          Text="9"
                          HeightRequest="54"
                          Command="{Binding MoneyPadInputCommand}"
                          CommandParameter="9"/>
                      <Button Grid.Row="3"
                          Grid.Column="3"
                          Style="{StaticResource QuickAmountButtonStyle}"
                          Text="$20"
                          HeightRequest="54"
                          Command="{Binding MoneyPadQuickAmountCommand}"
                          CommandParameter="20"/>

                      <Button Grid.Row="4"
                          Grid.Column="0"
                          Style="{StaticResource NumpadButtonStyle}"
                          Text="0"
                          HeightRequest="54"
                          Command="{Binding MoneyPadInputCommand}"
                          CommandParameter="0"/>
                      <Button Grid.Row="4"
                          Grid.Column="1"
                          Style="{StaticResource NumpadButtonStyle}"
                          Text="00"
                          HeightRequest="54"
                          Command="{Binding MoneyPadInputCommand}"
                          CommandParameter="00"/>
                      <Button Grid.Row="4"
                          Grid.Column="2"
                          Style="{StaticResource NumpadButtonStyle}"
                          Text="."
                          HeightRequest="54"
                          Command="{Binding MoneyPadInputCommand}"
                          CommandParameter="."/>
                      <Button Grid.Row="4"
                          Grid.Column="3"
                          Style="{StaticResource QuickAmountButtonStyle}"
                          Text="$10"
                          HeightRequest="54"
                          Command="{Binding MoneyPadQuickAmountCommand}"
                          CommandParameter="10"/>

                      <Button Grid.Row="5"
                          Grid.Column="0"
                              Style="{StaticResource NumpadButtonStyle}"
                              Text="C"
                              HeightRequest="48"
                              BackgroundColor="{DynamicResource ThemeDangerSurfaceColor}"
                              TextColor="{DynamicResource ThemeDangerTextColor}"
                              Command="{Binding MoneyPadClearCommand}"/>
                      <Button Grid.Row="5"
                          Grid.Column="1"
                              Style="{StaticResource NumpadButtonStyle}"
                              Text="⌫"
                              HeightRequest="48"
                              BackgroundColor="{DynamicResource ThemeDangerSurfaceColor}"
                              TextColor="{DynamicResource ThemeDangerTextColor}"
                              Command="{Binding MoneyPadBackspaceCommand}"/>
                      <Button Grid.Row="5"
                          Grid.Column="2"
                          Style="{StaticResource QuickAmountButtonStyle}"
                          Text="$500"
                          HeightRequest="48"
                          Command="{Binding MoneyPadQuickAmountCommand}"
                          CommandParameter="500"/>
                      <Button Grid.Row="5"
                          Grid.Column="3"
                          Style="{StaticResource QuickAmountButtonStyle}"
                          Text="$1000"
                          HeightRequest="48"
                          Command="{Binding MoneyPadQuickAmountCommand}"
                          CommandParameter="1000"/>
                    </Grid>
                  </Grid>

                  <!-- Row 4: footer Add Payment + Confirm -->
                  <Grid Grid.Row="4"
                        ColumnDefinitions="*,*"
                        ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Text="新增付款"
                            FontSize="{DynamicResource FontSizeButtonSmall}"
                            HeightRequest="42"
                            BackgroundColor="{DynamicResource ThemeAccentColor}"
                            TextColor="{DynamicResource ThemePrimaryButtonTextColor}"
                            FontAttributes="Bold"
                            Command="{Binding AddPaymentCommand}"/>
                    <Button Grid.Column="1"
                            Text="確認並收銀"
                            FontSize="{DynamicResource FontSizeButtonSmall}"
                            HeightRequest="42"
                            BackgroundColor="{DynamicResource ThemeAccentColor}"
                            TextColor="{DynamicResource ThemePrimaryButtonTextColor}"
                            FontAttributes="Bold"
                            Command="{Binding ConfirmCheckoutCommand}">
                      <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup Name="CommonStates">
                          <VisualState Name="Normal">
                            <VisualState.Setters>
                              <Setter Property="BackgroundColor"
                                  Value="{DynamicResource ThemeAccentColor}"/>
                              <Setter Property="TextColor"
                                  Value="{DynamicResource ThemePrimaryButtonTextColor}"/>
                            </VisualState.Setters>
                          </VisualState>
                          <VisualState Name="Disabled">
                            <VisualState.Setters>
                              <Setter Property="BackgroundColor"
                                  Value="{DynamicResource ThemeDisabledSurfaceColor}"/>
                              <Setter Property="TextColor"
                                  Value="{DynamicResource ThemeDisabledTextColor}"/>
                            </VisualState.Setters>
                          </VisualState>
                        </VisualStateGroup>
                      </VisualStateManager.VisualStateGroups>
                    </Button>
                  </Grid>
                </Grid>
              </Border>
            </ScrollView>
            <Grid x:Name="DailyAccountTabContent"
                  IsVisible="False"
                  RowDefinitions="Auto,*,Auto,Auto"
                  RowSpacing="0">
              <!-- ── Header: date nav + print ── -->
              <Grid Grid.Row="0"
                    ColumnDefinitions="*,Auto"
                    Padding="2,0,2,10">
                <Label Grid.Column="0"
                       Text="{Binding HeaderText}"
                       FontSize="{DynamicResource FontSizeSectionTitle}"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource ThemePrimaryTextColor}"
                       VerticalOptions="Center"/>
                <HorizontalStackLayout Grid.Column="1"
                                       Spacing="8">
                  <Button Text="◀ 上一日"
                          BackgroundColor="{DynamicResource ThemeBorderMutedColor}"
                          TextColor="{DynamicResource ThemePrimaryTextColor}"
                          Padding="12,6"
                          Command="{Binding PrevDayCommand}"/>
                  <Button Text="今日"
                          BackgroundColor="{DynamicResource ThemeActionBlueColor}"
                          TextColor="{DynamicResource ThemePrimaryTextColor}"
                          FontAttributes="Bold"
                          Padding="12,6"
                          Command="{Binding TodayCommand}"/>
                  <Button Text="下一日 ▶"
                          BackgroundColor="{DynamicResource ThemeBorderMutedColor}"
                          TextColor="{DynamicResource ThemePrimaryTextColor}"
                          Padding="12,6"
                          Command="{Binding NextDayCommand}"/>
                  <DatePicker Date="{Binding SelectedDate}"
                              TextColor="{DynamicResource ThemePrimaryTextColor}"
                              BackgroundColor="{DynamicResource ThemeSurfaceAltColor}"
                              FontSize="{DynamicResource FontSizeBodySmall}"/>
                  <Button Text="📊 匯出 Excel"
                          BackgroundColor="{DynamicResource ThemeAccentColor}"
                          TextColor="{DynamicResource ThemePrimaryButtonTextColor}"
                          FontAttributes="Bold"
                          Padding="12,6"
                          Command="{Binding ExportDailyReportCommand}"/>
                  <Button Text="🗑 清除記錄"
                          BackgroundColor="{DynamicResource ThemeDangerColor}"
                          TextColor="{DynamicResource ThemeDangerTextColor}"
                          FontAttributes="Bold"
                          Padding="12,6"
                          Command="{Binding DeleteDayDataCommand}"/>
                </HorizontalStackLayout>
              </Grid>

              <!-- ── Transaction table ── -->
              <Border Grid.Row="1"
                      Stroke="{DynamicResource ThemeBorderColor}"
                      StrokeThickness="1"
                      StrokeShape="RoundRectangle 12"
                      BackgroundColor="{DynamicResource ThemeSurfaceColor}">
                <CollectionView ItemsSource="{Binding Transactions}">
                  <CollectionView.Header>
                    <Grid ColumnDefinitions="60,2*,90,1.5*,88,56"
                          Padding="14,10"
                          BackgroundColor="{DynamicResource ThemeHeaderBarColor}">
                      <Label Grid.Column="0"
                          Text="編號"
                          TextColor="{DynamicResource ThemeInfoTextColor}"
                          FontSize="{DynamicResource FontSizeMicro}"
                          FontAttributes="Bold"
                          CharacterSpacing="1.2"/>
                      <Label Grid.Column="1"
                          Text="產品"
                          TextColor="{DynamicResource ThemeInfoTextColor}"
                          FontSize="{DynamicResource FontSizeMicro}"
                          FontAttributes="Bold"
                          CharacterSpacing="1.2"/>
                      <Label Grid.Column="2"
                          Text="時間"
                          TextColor="{DynamicResource ThemeInfoTextColor}"
                          FontSize="{DynamicResource FontSizeMicro}"
                          FontAttributes="Bold"
                          CharacterSpacing="1.2"/>
                      <Label Grid.Column="3"
                          Text="付款方式"
                          TextColor="{DynamicResource ThemeInfoTextColor}"
                          FontSize="{DynamicResource FontSizeMicro}"
                          FontAttributes="Bold"
                          CharacterSpacing="1.2"/>
                      <Label Grid.Column="4"
                          Text="金額"
                          TextColor="{DynamicResource ThemeInfoTextColor}"
                          FontSize="{DynamicResource FontSizeMicro}"
                          FontAttributes="Bold"
                          CharacterSpacing="1.2"
                          HorizontalOptions="End"/>
                      <Label Grid.Column="5"
                          Text=""/>
                    </Grid>
                  </CollectionView.Header>
                  <CollectionView.EmptyView>
                     <Label Text="所選日期沒有交易記錄。"
                           TextColor="{DynamicResource ThemeSecondaryTextColor}"
                           FontSize="{DynamicResource FontSizeBodySmall}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Margin="0,40"/>
                  </CollectionView.EmptyView>
                  <CollectionView.ItemTemplate>
                    <DataTemplate>
                      <VerticalStackLayout>
                        <Grid ColumnDefinitions="60,2*,90,1.5*,88,56"
                              Padding="14,11"
                              HorizontalOptions="Fill">
                          <!-- ID -->
                          <Label Grid.Column="0"
                                 TextColor="{DynamicResource ThemePrimaryTextColor}"
                                 FontSize="{DynamicResource FontSizeBodySmall}"
                                 FontAttributes="Bold"
                                 VerticalOptions="Start">
                            <Label.FormattedText>
                              <FormattedString>
                                 <Span Text="#"
                                    TextColor="{DynamicResource ThemeInfoTextColor}"/>
                                <Span Text="{Binding Id}"/>
                              </FormattedString>
                            </Label.FormattedText>
                          </Label>

                          <!-- Products (BindableLayout on VerticalStackLayout) -->
                          <VerticalStackLayout Grid.Column="1"
                                               Spacing="3"
                                               VerticalOptions="Start">
                            <BindableLayout.ItemsSource>
                              <Binding Path="Lines"/>
                            </BindableLayout.ItemsSource>
                            <BindableLayout.ItemTemplate>
                              <DataTemplate>
                                <Label FontSize="{DynamicResource FontSizeCaption}">
                                  <Label.FormattedText>
                                    <FormattedString>
                                      <Span Text="{Binding Quantity}"
                                          TextColor="{DynamicResource ThemeSecondaryTextColor}"/>
                                      <Span Text="× "
                                          TextColor="{DynamicResource ThemeSecondaryTextColor}"/>
                                      <Span Text="{Binding Name}"
                                          TextColor="{DynamicResource ThemePrimaryTextColor}"/>
                                      <Span Text="  "/>
                                      <Span Text="{Binding LineTotal, StringFormat='${0:F2}'}"
                                          TextColor="{DynamicResource ThemeSuccessTextColor}"/>
                                    </FormattedString>
                                  </Label.FormattedText>
                                </Label>
                              </DataTemplate>
                            </BindableLayout.ItemTemplate>
                          </VerticalStackLayout>

                          <!-- Timestamp -->
                          <VerticalStackLayout Grid.Column="2"
                                               Spacing="2"
                                               VerticalOptions="Start">
                            <Label Text="{Binding CreatedAtLocal, StringFormat='{0:yyyy-MM-dd}'}"
                                   TextColor="{DynamicResource ThemePrimaryTextColor}"
                                   FontSize="{DynamicResource FontSizeCaption}"
                                   FontAttributes="Bold"/>
                            <Label Text="{Binding CreatedAtLocal, StringFormat='{0:HH:mm:ss}'}"
                                   TextColor="{DynamicResource ThemeSecondaryTextColor}"
                                   FontSize="{DynamicResource FontSizeMicro}"/>
                          </VerticalStackLayout>

                          <!-- Payment methods (BindableLayout) -->
                          <VerticalStackLayout Grid.Column="3"
                                               Spacing="3"
                                               VerticalOptions="Start">
                            <BindableLayout.ItemsSource>
                              <Binding Path="Payments"/>
                            </BindableLayout.ItemsSource>
                            <BindableLayout.ItemTemplate>
                              <DataTemplate>
                                <Label FontSize="{DynamicResource FontSizeCaption}">
                                  <Label.FormattedText>
                                    <FormattedString>
                                      <Span Text="{Binding Method}"
                                          TextColor="{DynamicResource ThemeSecondaryTextColor}"
                                          FontAttributes="Bold"/>
                                      <Span Text="  $"
                                          TextColor="{DynamicResource ThemeInfoTextColor}"/>
                                      <Span Text="{Binding Amount, StringFormat='{0:F2}'}"
                                          TextColor="{DynamicResource ThemePrimaryTextColor}"/>
                                    </FormattedString>
                                  </Label.FormattedText>
                                </Label>
                              </DataTemplate>
                            </BindableLayout.ItemTemplate>
                          </VerticalStackLayout>

                          <!-- Amount -->
                          <Label Grid.Column="4"
                                 TextColor="{DynamicResource ThemeSuccessTextColor}"
                                 FontSize="{DynamicResource FontSizeBody}"
                                 FontAttributes="Bold"
                                 HorizontalOptions="End"
                                 VerticalOptions="Start">
                            <Label.FormattedText>
                              <FormattedString>
                                <Span Text="$"
                                    TextColor="{DynamicResource ThemeSecondaryTextColor}"
                                    FontSize="{DynamicResource FontSizeCaption}"/>
                                <Span Text="{Binding Total, StringFormat='{0:F2}'}"/>
                              </FormattedString>
                            </Label.FormattedText>
                          </Label>

                          <!-- Void button -->
                          <Button Grid.Column="5"
                                  Text="作廢"
                                  FontSize="{DynamicResource FontSizeMicro}"
                                  FontAttributes="Bold"
                                  BackgroundColor="{DynamicResource ThemeDangerColor}"
                                  TextColor="{DynamicResource ThemeDangerTextColor}"
                                  CornerRadius="6"
                                  Padding="4,2"
                                  HeightRequest="30"
                                  VerticalOptions="Center"
                                  Command="{Binding Source={x:Reference DailyAccountTabContent}, Path=BindingContext.VoidTransactionCommand}"
                                  CommandParameter="{Binding Id}"/>
                        </Grid>
                        <!-- Row separator -->
                        <BoxView HeightRequest="1"
                            BackgroundColor="{DynamicResource ThemeCardColor}"
                            HorizontalOptions="Fill"/>
                      </VerticalStackLayout>
                    </DataTemplate>
                  </CollectionView.ItemTemplate>
                </CollectionView>
              </Border>

              <!-- ── Footer summary bar ── -->
              <Border Grid.Row="2"
                      BackgroundColor="{DynamicResource ThemeHeaderBarColor}"
                      Stroke="{DynamicResource ThemeBorderColor}"
                      StrokeThickness="1"
                      StrokeShape="RoundRectangle 10"
                      Padding="16,12"
                      Margin="0,8,0,0">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="16">
                  <!-- Per-method totals -->
                  <FlexLayout BindableLayout.ItemsSource="{Binding ByMethod}"
                              Direction="Row"
                              Wrap="Wrap"
                              AlignItems="Center">
                    <BindableLayout.EmptyView>
                      <Label Text="暫無數據。"
                          TextColor="{DynamicResource ThemeInfoTextColor}"
                          FontSize="{DynamicResource FontSizeCaption}"/>
                    </BindableLayout.EmptyView>
                    <BindableLayout.ItemTemplate>
                      <DataTemplate>
                        <VerticalStackLayout Spacing="2"
                                             Margin="0,0,28,0">
                          <Label Text="{Binding Method}"
                                 TextColor="{DynamicResource ThemeInfoTextColor}"
                                 FontSize="{DynamicResource FontSizeTiny}"
                                 FontAttributes="Bold"
                                 CharacterSpacing="1.5"/>
                          <Label TextColor="{DynamicResource ThemePrimaryTextColor}"
                                 FontSize="{DynamicResource FontSizeButton}"
                                 FontAttributes="Bold">
                            <Label.FormattedText>
                              <FormattedString>
                                <Span Text="$"
                                    TextColor="{DynamicResource ThemeSecondaryTextColor}"
                                    FontSize="{DynamicResource FontSizeBodySmall}"/>
                                <Span Text="{Binding Amount, StringFormat='{0:F2}'}"/>
                              </FormattedString>
                            </Label.FormattedText>
                          </Label>
                          <Label TextColor="{DynamicResource ThemeInfoTextColor}"
                              FontSize="{DynamicResource FontSizeMicro}">
                            <Label.FormattedText>
                              <FormattedString>
                                <Span Text="{Binding Count}"/>
                                <Span Text=" txn(s)"/>
                              </FormattedString>
                            </Label.FormattedText>
                          </Label>
                        </VerticalStackLayout>
                      </DataTemplate>
                    </BindableLayout.ItemTemplate>
                  </FlexLayout>

                  <!-- Grand total panel -->
                  <Border Grid.Column="1"
                          BackgroundColor="{DynamicResource ThemeCardColor}"
                          Stroke="{DynamicResource ThemeBorderColor}"
                          StrokeThickness="1"
                          StrokeShape="RoundRectangle 8"
                          Padding="18,10">
                    <HorizontalStackLayout Spacing="0">
                      <VerticalStackLayout Spacing="3">
                        <Label Text="總收入"
                               TextColor="{DynamicResource ThemeInfoTextColor}"
                               FontSize="{DynamicResource FontSizeTiny}"
                               FontAttributes="Bold"
                               CharacterSpacing="1.5"/>
                        <Label Text="{Binding GrossTotalText}"
                               TextColor="{DynamicResource ThemeSuccessTextColor}"
                               FontSize="{DynamicResource FontSizePageSubTitle}"
                               FontAttributes="Bold"/>
                      </VerticalStackLayout>
                       <BoxView WidthRequest="1"
                               BackgroundColor="{DynamicResource ThemeBorderColor}"
                               Margin="16,0"
                               VerticalOptions="Fill"/>
                      <VerticalStackLayout Spacing="3">
                        <Label Text="交易次數"
                               TextColor="{DynamicResource ThemeInfoTextColor}"
                               FontSize="{DynamicResource FontSizeTiny}"
                               FontAttributes="Bold"
                               CharacterSpacing="1.5"/>
                        <Label Text="{Binding TransactionCountText}"
                               TextColor="{DynamicResource ThemePrimaryTextColor}"
                               FontSize="{DynamicResource FontSizePageSubTitle}"
                               FontAttributes="Bold"/>
                      </VerticalStackLayout>
                    </HorizontalStackLayout>
                  </Border>
                </Grid>
              </Border>

              <!-- Status message -->
              <HorizontalStackLayout Grid.Row="3"
                  Spacing="0"
                  Padding="2,4,2,0">
                <Label Text="{Binding StatusMessage}"
                       TextColor="{DynamicResource ThemeSecondaryTextColor}"
                       FontSize="{DynamicResource FontSizeCaption}"
                       VerticalOptions="Center"/>
                <Label Text="{Binding LastExportFileName}"
                       IsVisible="{Binding HasLastExport}"
                       TextColor="{DynamicResource ThemeLinkTextColor}"
                       FontSize="{DynamicResource FontSizeCaption}"
                       TextDecorations="Underline"
                       VerticalOptions="Center">
                  <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenLastExportCommand}"/>
                  </Label.GestureRecognizers>
                </Label>
              </HorizontalStackLayout>
            </Grid>
            <Grid x:Name="ConfigureTabContent"
                  IsVisible="False"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                  RowSpacing="10">
              <!-- ── Product Editor ── -->
              <Border Grid.Row="0"
                      Stroke="{DynamicResource ThemeBorderColor}"
                      StrokeShape="RoundRectangle 14"
                      BackgroundColor="{DynamicResource ThemeCardColor}"
                      Padding="14">
                <VerticalStackLayout Spacing="10">
                  <Grid ColumnDefinitions="Auto,*,Auto"
                        ColumnSpacing="10">
                    <Label Grid.Column="0"
                           Text="📦 產品"
                           TextColor="{DynamicResource ThemePrimaryTextColor}"
                           FontSize="{DynamicResource FontSizeSectionTitle}"
                           FontAttributes="Bold"
                           VerticalOptions="Center"/>
                    <Button Grid.Column="2"
                            Text="{Binding ProductConfigToggleText}"
                            FontSize="{DynamicResource FontSizeSectionTitle}"
                            FontAttributes="Bold"
                            Padding="4,0"
                            BackgroundColor="{DynamicResource ThemeTransparentColor}"
                            TextColor="{DynamicResource ThemePrimaryTextColor}"
                            Command="{Binding ToggleProductConfigSectionCommand}"/>
                  </Grid>

                  <Grid RowDefinitions="Auto,*"
                        RowSpacing="10"
                        IsVisible="{Binding IsProductConfigExpanded}">
                    <!-- Section header + column labels -->
                    <Grid ColumnDefinitions="Auto,*,120,80,80"
                          ColumnSpacing="10">
                      <Label Grid.Column="2"
                             Text="預設價格"
                             TextColor="{DynamicResource ThemeInfoTextColor}"
                             FontSize="{DynamicResource FontSizeMicro}"
                             FontAttributes="Bold"
                             CharacterSpacing="1.2"
                             VerticalOptions="Center"/>
                      <Label Grid.Column="3"
                             Text="儲存"
                             TextColor="{DynamicResource ThemeInfoTextColor}"
                             FontSize="{DynamicResource FontSizeMicro}"
                             FontAttributes="Bold"
                             CharacterSpacing="1.2"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"/>
                      <Label Grid.Column="4"
                             Text="刪除"
                             TextColor="{DynamicResource ThemeInfoTextColor}"
                             FontSize="{DynamicResource FontSizeMicro}"
                             FontAttributes="Bold"
                             CharacterSpacing="1.2"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"/>
                    </Grid>
                    <!-- Product rows -->
                    <CollectionView Grid.Row="1"
                                    ItemsSource="{Binding ProductEditorRows}"
                                    HeightRequest="220">
                      <CollectionView.EmptyView>
                        <Label Text="暫無產品。請在產品面板新增產品。"
                               TextColor="{DynamicResource ThemeSecondaryTextColor}"
                               FontSize="{DynamicResource FontSizeBodySmall}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Margin="0,20"/>
                      </CollectionView.EmptyView>
                      <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProductEditorRow">
                          <Grid ColumnDefinitions="Auto,*,120,80,80"
                                ColumnSpacing="10"
                                Padding="0,5">
                            <Label Grid.Column="0"
                                   TextColor="{DynamicResource ThemeInfoTextColor}"
                                   FontSize="{DynamicResource FontSizeBodySmall}"
                                   VerticalOptions="Center">
                              <Label.FormattedText>
                                <FormattedString>
                                  <Span Text="#"/>
                                  <Span Text="{Binding Id}"/>
                                </FormattedString>
                              </Label.FormattedText>
                            </Label>
                            <Entry Grid.Column="1"
                                   Text="{Binding Name}"
                                   TextColor="{DynamicResource ThemePrimaryTextColor}"
                                   BackgroundColor="{DynamicResource ThemeSurfaceColor}"
                                   FontSize="{DynamicResource FontSizeBodySmall}"/>
                            <Entry Grid.Column="2"
                                   Text="{Binding PriceText}"
                                   TextColor="{DynamicResource ThemeSuccessTextColor}"
                                   BackgroundColor="{DynamicResource ThemeSurfaceColor}"
                                   FontSize="{DynamicResource FontSizeBodySmall}"
                                   Keyboard="Numeric"/>
                            <Button Grid.Column="3"
                                    Text="💾"
                                    FontSize="{DynamicResource FontSizeSectionTitle}"
                                    BackgroundColor="{DynamicResource ThemeAccentColor}"
                                    TextColor="{DynamicResource ThemePrimaryButtonTextColor}"
                                    HeightRequest="40"
                                    WidthRequest="64"
                                    CornerRadius="8"
                                    Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.SaveProductCommand}"
                                    CommandParameter="{Binding .}"/>
                            <Button Grid.Column="4"
                                    Text="🗑"
                                    FontSize="{DynamicResource FontSizeSectionTitle}"
                                    BackgroundColor="{DynamicResource ThemeDangerColor}"
                                    TextColor="{DynamicResource ThemeDangerTextColor}"
                                    HeightRequest="40"
                                    WidthRequest="64"
                                    CornerRadius="8"
                                    Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.DeleteProductCommand}"
                                    CommandParameter="{Binding .}"/>
                          </Grid>
                        </DataTemplate>
                      </CollectionView.ItemTemplate>
                    </CollectionView>
                  </Grid>
                </VerticalStackLayout>
              </Border>

              <!-- ── Payment Methods Editor ── -->
              <Border Grid.Row="1"
                      Stroke="{DynamicResource ThemeBorderColor}"
                      StrokeShape="RoundRectangle 14"
                      BackgroundColor="{DynamicResource ThemeCardColor}"
                      Padding="14">
                <VerticalStackLayout Spacing="10">
                  <Grid ColumnDefinitions="Auto,*,Auto"
                        ColumnSpacing="10">
                    <Label Grid.Column="0"
                           Text="💳 付款方式"
                           TextColor="{DynamicResource ThemePrimaryTextColor}"
                           FontSize="{DynamicResource FontSizeSectionTitle}"
                           FontAttributes="Bold"
                           VerticalOptions="Center"/>
                    <Button Grid.Column="2"
                            Text="{Binding PaymentMethodsToggleText}"
                            FontSize="{DynamicResource FontSizeSectionTitle}"
                            FontAttributes="Bold"
                            Padding="4,0"
                            BackgroundColor="{DynamicResource ThemeTransparentColor}"
                            TextColor="{DynamicResource ThemePrimaryTextColor}"
                            Command="{Binding TogglePaymentMethodsSectionCommand}"/>
                  </Grid>

                  <Grid RowDefinitions="Auto,*,Auto"
                        RowSpacing="10"
                        IsVisible="{Binding IsPaymentMethodsExpanded}">
                    <!-- Section header -->
                    <Grid ColumnDefinitions="Auto,*,80,80"
                          ColumnSpacing="10">
                      <Label Grid.Column="2"
                             Text="儲存"
                             TextColor="{DynamicResource ThemeInfoTextColor}"
                             FontSize="{DynamicResource FontSizeMicro}"
                             FontAttributes="Bold"
                             CharacterSpacing="1.2"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"/>
                      <Label Grid.Column="3"
                             Text="刪除"
                             TextColor="{DynamicResource ThemeInfoTextColor}"
                             FontSize="{DynamicResource FontSizeMicro}"
                             FontAttributes="Bold"
                             CharacterSpacing="1.2"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"/>
                    </Grid>
                    <!-- Existing method rows -->
                    <CollectionView Grid.Row="1"
                                    ItemsSource="{Binding PaymentMethodEditorRows}"
                                    HeightRequest="160">
                      <CollectionView.EmptyView>
                        <Label Text="尚未設定付款方式。"
                               TextColor="{DynamicResource ThemeSecondaryTextColor}"
                               FontSize="{DynamicResource FontSizeBodySmall}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Margin="0,20"/>
                      </CollectionView.EmptyView>
                      <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:PaymentMethodEditorRow">
                          <Grid ColumnDefinitions="*,80,80"
                                ColumnSpacing="10"
                                Padding="0,5">
                            <Entry Grid.Column="0"
                                   Text="{Binding Name}"
                                   TextColor="{DynamicResource ThemePrimaryTextColor}"
                                   BackgroundColor="{DynamicResource ThemeSurfaceColor}"
                                   FontSize="{DynamicResource FontSizeBodySmall}"/>
                            <Button Grid.Column="1"
                                    Text="💾"
                                    FontSize="{DynamicResource FontSizeSectionTitle}"
                                    BackgroundColor="{DynamicResource ThemeAccentColor}"
                                    TextColor="{DynamicResource ThemePrimaryButtonTextColor}"
                                    HeightRequest="40"
                                    WidthRequest="64"
                                    CornerRadius="8"
                                    Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.SavePaymentMethodCommand}"
                                    CommandParameter="{Binding .}"/>
                            <Button Grid.Column="2"
                                    Text="🗑"
                                    FontSize="{DynamicResource FontSizeSectionTitle}"
                                    BackgroundColor="{DynamicResource ThemeDangerColor}"
                                    TextColor="{DynamicResource ThemeDangerTextColor}"
                                    HeightRequest="40"
                                    WidthRequest="64"
                                    CornerRadius="8"
                                    Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.DeletePaymentMethodCommand}"
                                    CommandParameter="{Binding .}"/>
                          </Grid>
                        </DataTemplate>
                      </CollectionView.ItemTemplate>
                    </CollectionView>
                    <!-- Add new method -->
                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                      <Entry Grid.Column="0"
                             Text="{Binding NewPaymentMethodName}"
                             Placeholder="新付款方式名稱（如：微信支付）"
                             PlaceholderColor="{DynamicResource ThemeInfoTextColor}"
                             TextColor="{DynamicResource ThemePrimaryTextColor}"
                             BackgroundColor="{DynamicResource ThemeSurfaceColor}"
                             FontSize="{DynamicResource FontSizeBodySmall}"/>
                      <Button Grid.Column="1"
                              Text="+ 新增"
                              FontSize="{DynamicResource FontSizeButtonSmall}"
                              FontAttributes="Bold"
                              BackgroundColor="{DynamicResource ThemeActionBlueSoftColor}"
                              TextColor="{DynamicResource ThemeWhiteColor}"
                              HeightRequest="44"
                              CornerRadius="8"
                              Command="{Binding AddPaymentMethodCommand}"/>
                    </Grid>
                  </Grid>
                </VerticalStackLayout>
              </Border>

              <!-- ── Printer Configure (collapsible) ── -->
              <Border Grid.Row="2"
                      Stroke="{DynamicResource ThemeBorderColor}"
                      StrokeShape="RoundRectangle 14"
                      BackgroundColor="{DynamicResource ThemeCardColor}"
                      Padding="14">
                <VerticalStackLayout Spacing="10">
                  <Grid ColumnDefinitions="Auto,*,Auto"
                        ColumnSpacing="10">
                    <Label Grid.Column="0"
                           Text="🖨 印表機設置"
                           FontSize="{DynamicResource FontSizeSectionTitle}"
                           FontAttributes="Bold"
                           TextColor="{DynamicResource ThemePrimaryTextColor}"
                           VerticalOptions="Center"/>
                    <Button Grid.Column="2"
                            Text="{Binding PrinterSettingsToggleText}"
                            FontSize="{DynamicResource FontSizeSectionTitle}"
                            FontAttributes="Bold"
                            Padding="4,0"
                            BackgroundColor="{DynamicResource ThemeTransparentColor}"
                            TextColor="{DynamicResource ThemePrimaryTextColor}"
                            Command="{Binding TogglePrinterSettingsSectionCommand}"/>
                  </Grid>

                  <VerticalStackLayout Spacing="10"
                                       IsVisible="{Binding IsPrinterSettingsExpanded}">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="10">
                      <Label Grid.Column="0"
                             Text="連接狀態"
                             TextColor="{DynamicResource ThemeSecondaryTextColor}"
                             VerticalOptions="Center"/>
                      <Border Grid.Column="1"
                              StrokeThickness="0"
                              StrokeShape="RoundRectangle 999"
                              BackgroundColor="{DynamicResource ThemeSurfaceColor}"
                              Padding="10,4"
                              HorizontalOptions="Start"
                              VerticalOptions="Center">
                        <Label Text="{Binding ConnectionStateText}"
                               FontSize="{DynamicResource FontSizeBodySmall}"
                               FontAttributes="Bold"
                               TextColor="{Binding IsPrinterConnected, Converter={StaticResource BoolToConnectedColorConverter}}"/>
                      </Border>
                    </Grid>

                    <BoxView HeightRequest="1"
                             BackgroundColor="{DynamicResource ThemeBorderColor}"/>

                    <!-- Mode + Port -->
                    <Grid ColumnDefinitions="Auto,*,Auto,*"
                          ColumnSpacing="10">
                      <Label Grid.Column="0"
                          Text="模式"
                          TextColor="{DynamicResource ThemeSecondaryTextColor}"
                          VerticalOptions="Center"/>
                      <Picker Grid.Column="1"
                              Title="USB 或 COM"
                              ItemsSource="{Binding ConnectionModes}"
                              SelectedItem="{Binding ConnectionOptions.Mode}"/>
                      <Label Grid.Column="2"
                          Text="連接埠"
                          TextColor="{DynamicResource ThemeSecondaryTextColor}"
                          VerticalOptions="Center"/>
                      <Entry Grid.Column="3"
                             Placeholder="已安裝印表機名稱（如：POS-80）"
                             Text="{Binding ConnectionOptions.Endpoint}"/>
                    </Grid>
                    <!-- Connect / Disconnect -->
                    <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="10">
                      <Button Grid.Column="0"
                              Text="連接印表機"
                              HeightRequest="48"
                              FontAttributes="Bold"
                              BackgroundColor="{DynamicResource ThemeActionTealColor}"
                              TextColor="{DynamicResource ThemeWhiteColor}"
                              Command="{Binding ConnectPrinterCommand}"/>
                      <Button Grid.Column="1"
                              Text="中斷連接"
                              HeightRequest="48"
                              FontAttributes="Bold"
                              BackgroundColor="{DynamicResource ThemeBorderMutedColor}"
                              TextColor="{DynamicResource ThemePrimaryTextColor}"
                              Command="{Binding DisconnectPrinterCommand}"/>
                    </Grid>
                    <!-- Open Drawer / Print Test -->
                    <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="10">
                      <Button Grid.Column="0"
                              Text="開錢箱"
                              HeightRequest="48"
                              FontAttributes="Bold"
                              BackgroundColor="{DynamicResource ThemeActionWarmColor}"
                              TextColor="{DynamicResource ThemeWhiteColor}"
                              Command="{Binding OpenDrawerCommand}"/>
                      <Button Grid.Column="1"
                              Text="列印測試"
                              HeightRequest="48"
                              FontAttributes="Bold"
                              BackgroundColor="{DynamicResource ThemeActionBlueColor}"
                              TextColor="{DynamicResource ThemePrimaryTextColor}"
                              Command="{Binding PrintPrinterTestCommand}"/>
                    </Grid>
                    <!-- Console (always visible in expanded card) -->
                    <BoxView HeightRequest="1"
                             BackgroundColor="{DynamicResource ThemeBorderColor}"/>
                    <Grid RowDefinitions="Auto,*"
                          RowSpacing="6"
                          Padding="0,2,0,0">
                      <Label Text="印表機控制台"
                             FontSize="{DynamicResource FontSizeBodySmall}"
                             FontAttributes="Bold"
                             TextColor="{DynamicResource ThemePrimaryTextColor}"/>
                      <ScrollView Grid.Row="1"
                                  HeightRequest="140">
                        <Label Text="{Binding PrinterConsoleText}"
                               TextColor="{DynamicResource ThemeSecondaryTextColor}"
                               FontFamily="Courier New"
                               FontSize="{DynamicResource FontSizeBodySmall}"
                               LineBreakMode="WordWrap"/>
                      </ScrollView>
                    </Grid>
                  </VerticalStackLayout>

                </VerticalStackLayout>
              </Border>

              <Border Grid.Row="3"
                      Stroke="{DynamicResource ThemeBorderColor}"
                      StrokeShape="RoundRectangle 14"
                      BackgroundColor="{DynamicResource ThemeCardColor}"
                      Padding="14">
                <VerticalStackLayout Spacing="12">
                  <Grid ColumnDefinitions="Auto,*,Auto"
                        ColumnSpacing="10">
                    <Label Grid.Column="0"
                           Text="🎨 自訂外觀設定"
                           FontSize="{DynamicResource FontSizeSectionTitle}"
                           FontAttributes="Bold"
                           TextColor="{DynamicResource ThemePrimaryTextColor}"/>
                    <Button Grid.Column="2"
                            Text="{Binding AppearanceSettingsToggleText}"
                            FontSize="{DynamicResource FontSizeSectionTitle}"
                            FontAttributes="Bold"
                            Padding="4,0"
                            BackgroundColor="{DynamicResource ThemeTransparentColor}"
                            TextColor="{DynamicResource ThemePrimaryTextColor}"
                            Command="{Binding ToggleAppearanceSectionCommand}"/>
                  </Grid>

                  <VerticalStackLayout Spacing="12"
                                       IsVisible="{Binding IsAppearanceSettingsExpanded}">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="10">
                      <Label Grid.Column="0"
                             Text="字體縮放"
                             TextColor="{DynamicResource ThemeSecondaryTextColor}"
                             VerticalOptions="Center"/>
                      <Slider Grid.Column="1"
                              Minimum="0.8"
                              Maximum="1.6"
                              Value="{Binding UiFontScale}"/>
                      <Label Grid.Column="2"
                             Text="{Binding UiFontScaleText}"
                             TextColor="{DynamicResource ThemePrimaryTextColor}"
                             VerticalOptions="Center"/>
                    </Grid>

                    <Grid ColumnDefinitions="2*,Auto,2*,Auto"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="8">
                      <Label Grid.Row="0"
                             Grid.Column="0"
                             Text="主文字 #RRGGBB"
                             TextColor="{DynamicResource ThemeSecondaryTextColor}"/>
                      <BoxView Grid.Row="0"
                               Grid.Column="1"
                               WidthRequest="24"
                               HeightRequest="24"
                               CornerRadius="4"
                               Color="{Binding UiPrimaryTextColorHex}"/>
                      <Entry Grid.Row="0"
                             Grid.Column="2"
                             Text="{Binding UiPrimaryTextColorHex}"
                             Placeholder="#D2E4FB"
                             TextColor="{DynamicResource ThemePrimaryTextColor}"
                             BackgroundColor="{DynamicResource ThemeSurfaceColor}"/>

                      <Label Grid.Row="1"
                             Grid.Column="0"
                             Text="次文字 #RRGGBB"
                             TextColor="{DynamicResource ThemeSecondaryTextColor}"/>
                      <BoxView Grid.Row="1"
                               Grid.Column="1"
                               WidthRequest="24"
                               HeightRequest="24"
                               CornerRadius="4"
                               Color="{Binding UiSecondaryTextColorHex}"/>
                      <Entry Grid.Row="1"
                             Grid.Column="2"
                             Text="{Binding UiSecondaryTextColorHex}"
                             Placeholder="#8EA0B9"
                             TextColor="{DynamicResource ThemePrimaryTextColor}"
                             BackgroundColor="{DynamicResource ThemeSurfaceColor}"/>
                    </Grid>

                    <Grid ColumnDefinitions="2*,Auto,2*,Auto"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="8">
                      <Label Grid.Row="0"
                             Grid.Column="0"
                             Text="背景 #RRGGBB"
                             TextColor="{DynamicResource ThemeSecondaryTextColor}"/>
                      <BoxView Grid.Row="0"
                               Grid.Column="1"
                               WidthRequest="24"
                               HeightRequest="24"
                               CornerRadius="4"
                               Color="{Binding UiBackgroundColorHex}"/>
                      <Entry Grid.Row="0"
                             Grid.Column="2"
                             Text="{Binding UiBackgroundColorHex}"
                             Placeholder="#031425"
                             TextColor="{DynamicResource ThemePrimaryTextColor}"
                             BackgroundColor="{DynamicResource ThemeSurfaceColor}"/>

                      <Label Grid.Row="1"
                             Grid.Column="0"
                             Text="強調色 #RRGGBB"
                             TextColor="{DynamicResource ThemeSecondaryTextColor}"/>
                      <BoxView Grid.Row="1"
                               Grid.Column="1"
                               WidthRequest="24"
                               HeightRequest="24"
                               CornerRadius="4"
                               Color="{Binding UiAccentColorHex}"/>
                      <Entry Grid.Row="1"
                             Grid.Column="2"
                             Text="{Binding UiAccentColorHex}"
                             Placeholder="#A2D149"
                             TextColor="{DynamicResource ThemePrimaryTextColor}"
                             BackgroundColor="{DynamicResource ThemeSurfaceColor}"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                      <Button Grid.Column="0"
                              Text="套用外觀"
                              FontAttributes="Bold"
                              BackgroundColor="{DynamicResource ThemeAccentColor}"
                              TextColor="{DynamicResource ThemePrimaryButtonTextColor}"
                              Command="{Binding ApplyAppearanceCommand}"/>
                      <Button Grid.Column="1"
                              Text="重設預設"
                              FontAttributes="Bold"
                              BackgroundColor="{DynamicResource ThemeBorderMutedColor}"
                              TextColor="{DynamicResource ThemePrimaryTextColor}"
                              Command="{Binding ResetAppearanceCommand}"/>
                    </Grid>
                  </VerticalStackLayout>
                </VerticalStackLayout>
              </Border>

              <Label Grid.Row="4"
                     Text="{Binding StatusMessage}"
                     TextColor="{DynamicResource ThemeSecondaryTextColor}"
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     VerticalOptions="Start"/>
            </Grid>
          </Grid>
        </Grid>
      </Border>

      <Grid Grid.Column="0"
            RowDefinitions="Auto,*,Auto"
            RowSpacing="10">
        <Border Stroke="{DynamicResource ThemeBorderColor}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 14"
                BackgroundColor="{DynamicResource ThemeSurfaceColor}"
                Padding="12">
          <VerticalStackLayout Spacing="10">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="10">

              <Grid Grid.Row="4"
                    Grid.ColumnSpan="3"
                    ColumnDefinitions="*,Auto"
                    ColumnSpacing="8">
                <VerticalStackLayout Grid.Column="0"
                                     Spacing="2">
                  <Label Text="印表機連接"
                         FontSize="{DynamicResource FontSizeSectionTitle}"
                         FontAttributes="Bold"
                         TextColor="{DynamicResource ThemePrimaryTextColor}"/>
                  <Label Text="{Binding ConnectionStateText}">
                    <Label.Triggers>
                      <DataTrigger TargetType="Label"
                                   Binding="{Binding IsPrinterConnected}"
                                   Value="True">
                        <Setter Property="TextColor"
                                Value="{DynamicResource ThemeSuccessTextColor}"/>
                      </DataTrigger>
                      <DataTrigger TargetType="Label"
                                   Binding="{Binding IsPrinterConnected}"
                                   Value="False">
                        <Setter Property="TextColor"
                                Value="{DynamicResource ThemeDangerTextColor}"/>
                      </DataTrigger>
                    </Label.Triggers>
                  </Label>
                </VerticalStackLayout>
                <HorizontalStackLayout Grid.Column="1"
                                       Spacing="8">
                  <Button Text="連接"
                          BackgroundColor="{DynamicResource ThemeActionTealColor}"
                          TextColor="{DynamicResource ThemeWhiteColor}"
                          FontAttributes="Bold"
                          Command="{Binding ConnectPrinterCommand}"/>
                  <Button Text="中斷連接"
                          BackgroundColor="{DynamicResource ThemeBorderMutedColor}"
                          TextColor="{DynamicResource ThemePrimaryTextColor}"
                          FontAttributes="Bold"
                          Command="{Binding DisconnectPrinterCommand}"/>
                </HorizontalStackLayout>
              </Grid>

            </Grid>
          </VerticalStackLayout>
        </Border>

        <Grid Grid.Row="1">
          <Border Stroke="{DynamicResource ThemeBorderColor}"
                  StrokeThickness="1"
                  StrokeShape="RoundRectangle 14"
                  BackgroundColor="{DynamicResource ThemeSurfaceColor}"
                  Padding="14">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="12">
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="10">
                <Label Text="產品"
                       TextColor="{DynamicResource ThemePrimaryTextColor}"
                       FontSize="{DynamicResource FontSizePageSubTitle}"
                       FontAttributes="Bold"/>
                <Button Grid.Column="1"
                        Text="+ 新增產品"
                        FontAttributes="Bold"
                        BackgroundColor="{DynamicResource ThemeAccentColor}"
                        TextColor="{DynamicResource ThemePrimaryButtonTextColor}"
                        Command="{Binding OpenAddProductPopupCommand}"/>
              </Grid>

              <CollectionView Grid.Row="1"
                              ItemsSource="{Binding PresetItems}"
                              SelectionMode="None">
                <CollectionView.ItemsLayout>
                  <GridItemsLayout Orientation="Vertical"
                                   Span="3"
                                   HorizontalItemSpacing="10"
                                   VerticalItemSpacing="10"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                  <DataTemplate>
                    <Border Stroke="{DynamicResource ThemeBorderMutedColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{DynamicResource ThemeSurfaceAltColor}"
                            Padding="12"
                            MinimumHeightRequest="110">
                      <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AddItemCommand}"
                                              CommandParameter="{Binding}"/>
                      </Border.GestureRecognizers>
                      <VerticalStackLayout Spacing="8"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center">
                        <Label Text="{Binding Name}"
                               FontSize="{DynamicResource FontSizeSectionTitle}"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource ThemePrimaryTextColor}"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="{Binding DefaultPrice, StringFormat='HKD $ {0:F2}'}"
                               TextColor="{DynamicResource ThemeHighlightColor}"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="點擊新增"
                               FontSize="{DynamicResource FontSizeCaption}"
                               TextColor="{DynamicResource ThemeSecondaryTextColor}"
                               HorizontalTextAlignment="Center"/>
                      </VerticalStackLayout>
                    </Border>
                  </DataTemplate>
                </CollectionView.ItemTemplate>
              </CollectionView>
            </Grid>
          </Border>

        </Grid>

        <Label Grid.Row="2"
               Text="在 macOS 上，目前預設印表機為模擬/檔案輸出。"
               FontSize="{DynamicResource FontSizeCaption}"
               TextColor="{DynamicResource ThemeSecondaryTextColor}"
               Opacity="0.9"/>
      </Grid>
    </Grid>
    <Grid Grid.RowSpan="1"
          IsVisible="{Binding IsAddProductPopupVisible}"
          BackgroundColor="{DynamicResource ThemeOverlayColor}">
      <Border Stroke="{DynamicResource ThemeBorderColor}"
              StrokeThickness="1"
              StrokeShape="RoundRectangle 14"
              BackgroundColor="{DynamicResource ThemeSurfaceColor}"
              Padding="16"
              HorizontalOptions="Center"
              VerticalOptions="Center"
              WidthRequest="320">
        <VerticalStackLayout Spacing="12">
          <Label Text="新增產品"
                 FontSize="{DynamicResource FontSizePageSubTitle}"
                 FontAttributes="Bold"
                 TextColor="{DynamicResource ThemePrimaryTextColor}"/>

          <Entry Placeholder="產品名稱"
                 Text="{Binding NewProductName}"/>
          <Entry Placeholder="價格（如：12.5）"
                 Keyboard="Numeric"
                 Text="{Binding NewProductPriceText}"/>

          <Grid ColumnDefinitions="*,*"
                ColumnSpacing="10">
            <Button Grid.Column="0"
                    Text="取消"
                    BackgroundColor="{DynamicResource ThemeBorderMutedColor}"
                    TextColor="{DynamicResource ThemePrimaryTextColor}"
                    FontAttributes="Bold"
                    Command="{Binding CloseAddProductPopupCommand}"/>
            <Button Grid.Column="1"
                    Text="新增"
                    BackgroundColor="{DynamicResource ThemeAccentColor}"
                    TextColor="{DynamicResource ThemePrimaryButtonTextColor}"
                    FontAttributes="Bold"
                    Command="{Binding AddNewProductCommand}"/>
          </Grid>
        </VerticalStackLayout>
      </Border>
    </Grid>
  </Grid>
</ContentPage>
