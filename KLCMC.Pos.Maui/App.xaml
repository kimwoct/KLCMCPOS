<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:KLCMC.Pos.Maui.Converters"
             x:Class="KLCMC.Pos.Maui.App">
  <Application.Resources>
    <conv:BoolToTileBgConverter x:Key="BoolToTileBg" />
    <Color x:Key="ThemeBackgroundColor">#031425</Color>
    <Color x:Key="ThemePrimaryTextColor">#D2E4FB</Color>
    <Color x:Key="ThemeSecondaryTextColor">#8EA0B9</Color>
    <Color x:Key="ThemeAccentColor">#A2D149</Color>
    <x:Double x:Key="ThemeFontScale">1</x:Double>
    <x:Double x:Key="FontSizePageTitle">32</x:Double>
    <x:Double x:Key="FontSizePageSubTitle">26</x:Double>
    <x:Double x:Key="FontSizeBody">16</x:Double>
    <x:Double x:Key="FontSizeButton">20</x:Double>
    <x:Double x:Key="FontSizeSectionTitle">18</x:Double>
  </Application.Resources>
</Application>
