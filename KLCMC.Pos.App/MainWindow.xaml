<Window x:Class="KLCMC.Pos.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        mc:Ignorable="d"
        Title="KLCMC POS"
        Height="680"
        Width="1100"
        MinHeight="620"
        MinWidth="980">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
  </Window.Resources>
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" BorderThickness="1" BorderBrush="#DDD" CornerRadius="4" Padding="10" Margin="0,0,0,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="150" />
          <ColumnDefinition Width="220" />
          <ColumnDefinition Width="95" />
          <ColumnDefinition Width="95" />
          <ColumnDefinition Width="95" />
          <ColumnDefinition Width="95" />
          <ColumnDefinition Width="95" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Connection Mode" />
        <ComboBox Grid.Column="1"
                  Margin="8,0,12,0"
                  ItemsSource="{Binding ConnectionModes}"
                  SelectedItem="{Binding ConnectionOptions.Mode}" />

        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Endpoint" />
        <TextBox Grid.Column="3"
                 Margin="8,0,12,0"
                 Grid.ColumnSpan="2"
                 Text="{Binding ConnectionOptions.Endpoint, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Column="5" VerticalAlignment="Center" Text="Baud" />
        <TextBox Grid.Column="6" Margin="8,0,12,0" Text="{Binding ConnectionOptions.BaudRate}" />

        <StackPanel Grid.Column="7" Orientation="Horizontal" Margin="0,0,12,0">
          <TextBlock VerticalAlignment="Center" Text="DataBits" />
          <TextBox Width="50" Margin="8,0,0,0" Text="{Binding ConnectionOptions.DataBits}" />
        </StackPanel>

        <StackPanel Grid.Column="8" Orientation="Horizontal" Margin="0,0,12,0">
          <TextBlock VerticalAlignment="Center" Text="StopBits" />
          <TextBox Width="50" Margin="8,0,0,0" Text="{Binding ConnectionOptions.StopBits}" />
        </StackPanel>

        <StackPanel Grid.Column="9" Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Width="90"
                  Margin="0,0,8,0"
                  Command="{Binding ConnectPrinterCommand}"
                  Content="Connect" />
          <Button Width="90"
                  Margin="0,0,8,0"
                  Command="{Binding DisconnectPrinterCommand}"
                  Content="Disconnect" />
          <TextBlock VerticalAlignment="Center"
                     FontWeight="SemiBold"
                     Text="{Binding ConnectionStateText}" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="320" />
        <ColumnDefinition Width="10" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" BorderThickness="1" BorderBrush="#DDD" CornerRadius="4" Padding="10">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Margin="0,0,0,8" FontSize="16" FontWeight="SemiBold" Text="Preset Items" />
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding PresetItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Margin="0,0,0,8"
                          Padding="8"
                          HorizontalContentAlignment="Left"
                          Command="{Binding DataContext.AddItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                          CommandParameter="{Binding}">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="{Binding Name}" />
                      <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{Binding DefaultPrice, StringFormat=HKD $ {0:F2}}" />
                    </Grid>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <Border Grid.Column="2" BorderThickness="1" BorderBrush="#DDD" CornerRadius="4" Padding="10">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Margin="0,0,0,8" FontSize="16" FontWeight="SemiBold" Text="Cart" />
          <DataGrid ItemsSource="{Binding CartLines}"
                    SelectedItem="{Binding SelectedCartLine}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Item" Binding="{Binding Name}" IsReadOnly="True" Width="2*" />
              <DataGridTextColumn Header="Qty" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="*" />
              <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" Width="*" />
              <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotal, StringFormat={}{0:F2}}" IsReadOnly="True" Width="*" />
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>
    </Grid>

    <Border Grid.Row="2" BorderThickness="1" BorderBrush="#DDD" CornerRadius="4" Padding="10" Margin="0,10,0,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="#555" Text="{Binding StatusMessage}" />
        <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="0,0,14,0" FontSize="18" FontWeight="SemiBold" Text="{Binding TotalText}" />
        <Button Grid.Column="2" Width="120" Margin="0,0,8,0" Click="OnDailyAccountClick" Content="Daily Account" />
        <Button Grid.Column="3" Width="100" Margin="0,0,8,0" Command="{Binding ClearCartCommand}" Content="Clear" />
        <Button Grid.Column="4" Width="140" Command="{Binding PrintReceiptCommand}" Content="Checkout" />
      </Grid>
    </Border>

    <!-- Checkout popup overlay -->
    <Grid Grid.Row="0" Grid.RowSpan="3"
          Background="#A0000000"
          Visibility="{Binding IsCheckoutPopupVisible, Converter={StaticResource BoolToVis}}">
      <Border Background="White" BorderBrush="#CCC" BorderThickness="1" CornerRadius="6"
              Padding="16" HorizontalAlignment="Center" VerticalAlignment="Center"
              MinWidth="640" MaxWidth="820">
        <StackPanel>
          <TextBlock Text="Checkout" FontSize="22" FontWeight="Bold" />
          <TextBlock Text="{Binding AmountDueText}" FontSize="18" FontWeight="Bold" Foreground="#2E7D32" Margin="0,8,0,0" />
          <TextBlock Text="{Binding PaidTotalText}" FontSize="14" Margin="0,2,0,0" />
          <TextBlock Text="{Binding OutstandingText}" FontSize="14" FontWeight="Bold" Foreground="#C77800" Margin="0,2,0,8" />

          <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="6" MinHeight="60">
            <ItemsControl ItemsSource="{Binding Payments}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding DisplayText}" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="Remove"
                            Command="{Binding DataContext.RemovePaymentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>

          <Grid Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,8,0">
              <TextBlock Text="Payment Method" FontWeight="SemiBold" />
              <ComboBox ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding SelectedNewPaymentMethod}" Margin="0,4" />
              <TextBlock Text="{Binding MoneyPadLabelText}" FontWeight="SemiBold" Margin="0,8,0,0" />
              <Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="4" Padding="10,6" Margin="0,4">
                <TextBlock Text="{Binding MoneyPadInputText}" FontSize="22" FontWeight="Bold" TextAlignment="Right" />
              </Border>
              <TextBlock Text="{Binding ChangePreviewText}" Foreground="#2E7D32" FontWeight="Bold" />
              <Button Content="Add Payment" Height="40" Margin="0,8,0,0" FontWeight="Bold"
                      Command="{Binding AddPaymentCommand}" />
            </StackPanel>

            <UniformGrid Grid.Column="1" Rows="5" Columns="4" Margin="8,0,0,0">
              <Button Content="7" FontSize="16" Margin="2" Command="{Binding MoneyPadInputCommand}" CommandParameter="7" />
              <Button Content="8" FontSize="16" Margin="2" Command="{Binding MoneyPadInputCommand}" CommandParameter="8" />
              <Button Content="9" FontSize="16" Margin="2" Command="{Binding MoneyPadInputCommand}" CommandParameter="9" />
              <Button Content="20" FontSize="14" Margin="2" Command="{Binding MoneyPadQuickAmountCommand}" CommandParameter="20" />
              <Button Content="4" FontSize="16" Margin="2" Command="{Binding MoneyPadInputCommand}" CommandParameter="4" />
              <Button Content="5" FontSize="16" Margin="2" Command="{Binding MoneyPadInputCommand}" CommandParameter="5" />
              <Button Content="6" FontSize="16" Margin="2" Command="{Binding MoneyPadInputCommand}" CommandParameter="6" />
              <Button Content="50" FontSize="14" Margin="2" Command="{Binding MoneyPadQuickAmountCommand}" CommandParameter="50" />
              <Button Content="1" FontSize="16" Margin="2" Command="{Binding MoneyPadInputCommand}" CommandParameter="1" />
              <Button Content="2" FontSize="16" Margin="2" Command="{Binding MoneyPadInputCommand}" CommandParameter="2" />
              <Button Content="3" FontSize="16" Margin="2" Command="{Binding MoneyPadInputCommand}" CommandParameter="3" />
              <Button Content="100" FontSize="14" Margin="2" Command="{Binding MoneyPadQuickAmountCommand}" CommandParameter="100" />
              <Button Content="0" FontSize="16" Margin="2" Command="{Binding MoneyPadInputCommand}" CommandParameter="0" />
              <Button Content="00" FontSize="16" Margin="2" Command="{Binding MoneyPadInputCommand}" CommandParameter="00" />
              <Button Content="." FontSize="16" Margin="2" Command="{Binding MoneyPadInputCommand}" CommandParameter="." />
              <Button Content="500" FontSize="14" Margin="2" Command="{Binding MoneyPadQuickAmountCommand}" CommandParameter="500" />
              <Button Content="C" FontSize="14" Margin="2" Command="{Binding MoneyPadClearCommand}" />
              <Button Content="⌫" FontSize="14" Margin="2" Command="{Binding MoneyPadBackspaceCommand}" />
              <Button Content="Exact" FontSize="14" FontWeight="Bold" Margin="2" Command="{Binding MoneyPadQuickAmountCommand}" CommandParameter="EXACT" Grid.ColumnSpan="2" />
              <Button Content="" Margin="2" IsEnabled="False" Visibility="Hidden" />
            </UniformGrid>
          </Grid>

          <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Cancel" Height="44" Margin="0,0,6,0" Command="{Binding CancelCheckoutCommand}" />
            <Button Grid.Column="1" Content="Confirm and Print" Height="44" Margin="6,0,0,0" FontWeight="Bold"
                    Background="#A2D149" Command="{Binding ConfirmCheckoutCommand}" />
          </Grid>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</Window>
