<Window x:Class="KLCMC.Pos.App.DailyAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Daily Account"
        Height="700"
        Width="980"
        MinHeight="540"
        MinWidth="800">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" BorderThickness="1" BorderBrush="#DDD" CornerRadius="4" Padding="10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Text="{Binding HeaderText}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />
        <StackPanel Grid.Column="1" Orientation="Horizontal">
          <Button Content="Prev" Width="80" Margin="2" Command="{Binding PrevDayCommand}" />
          <Button Content="Today" Width="80" Margin="2" FontWeight="Bold" Command="{Binding TodayCommand}" />
          <Button Content="Next" Width="80" Margin="2" Command="{Binding NextDayCommand}" />
          <DatePicker SelectedDate="{Binding SelectedDate}" Width="140" Margin="6,2,2,2" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="0,10,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Border Grid.Column="0" BorderThickness="1" BorderBrush="#DDD" CornerRadius="4" Padding="10" Margin="0,0,5,0">
        <StackPanel>
          <TextBlock Text="Transactions" Foreground="#666" />
          <TextBlock Text="{Binding TransactionCountText}" FontSize="20" FontWeight="Bold" />
        </StackPanel>
      </Border>
      <Border Grid.Column="1" BorderThickness="1" BorderBrush="#DDD" CornerRadius="4" Padding="10" Margin="5,0">
        <StackPanel>
          <TextBlock Text="Gross Total" Foreground="#666" />
          <TextBlock Text="{Binding GrossTotalText}" FontSize="20" FontWeight="Bold" Foreground="#2E7D32" />
        </StackPanel>
      </Border>
      <Button Grid.Column="2" Content="Print Daily Report" Width="180" Height="60" Margin="6,0,0,0" FontWeight="Bold"
              Background="#A2D149" Command="{Binding PrintDailyReportCommand}" />
    </Grid>

    <Border Grid.Row="2" BorderThickness="1" BorderBrush="#DDD" CornerRadius="4" Padding="10" Margin="0,10,0,0">
      <StackPanel>
        <TextBlock Text="By Payment Method" FontWeight="Bold" />
        <ItemsControl ItemsSource="{Binding ByMethod}" Margin="0,6,0,0">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="10,6" Margin="0,0,8,0" MinWidth="140">
                <StackPanel>
                  <TextBlock Text="{Binding Method}" Foreground="#666" />
                  <TextBlock FontSize="16" FontWeight="Bold">
                    <Run Text="HKD $" />
                    <Run Text="{Binding Amount, StringFormat=F2, Mode=OneWay}" />
                  </TextBlock>
                  <TextBlock Foreground="#888" FontSize="11">
                    <Run Text="{Binding Count, Mode=OneWay}" />
                    <Run Text=" txn(s)" />
                  </TextBlock>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>

    <Border Grid.Row="3" BorderThickness="1" BorderBrush="#DDD" CornerRadius="4" Padding="10" Margin="0,10,0,0">
      <DataGrid ItemsSource="{Binding Transactions}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="60" />
          <DataGridTextColumn Header="Time" Binding="{Binding CreatedAtLocal, StringFormat=HH:mm:ss}" Width="100" />
          <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=F2}" Width="100" />
          <DataGridTemplateColumn Header="Payments" Width="*">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <ItemsControl ItemsSource="{Binding Payments}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="#EEF3F8" CornerRadius="10" Padding="6,2" Margin="0,0,4,0">
                        <TextBlock>
                          <Run Text="{Binding Method, Mode=OneWay}" />
                          <Run Text=" $" />
                          <Run Text="{Binding Amount, StringFormat=F2, Mode=OneWay}" />
                        </TextBlock>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <TextBlock Grid.Row="4" Foreground="#666" Margin="0,8,0,0" Text="{Binding StatusMessage}" />
  </Grid>
</Window>
